{"dependencies":[],"output":[{"data":{"code":"__d(function(global, require, _importDefaultUnused, _importAllUnused, module, exports, _dependencyMapUnused) {\n  module.exports = {\n  \"Book\": [\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01001001\",\n              \"Verse\": \"In the beginning God created the heaven and the earth.\"\n            },\n            {\n              \"Verseid\": \"01001002\",\n              \"Verse\": \"And the earth was without form, and void; and darkness was upon the face of the deep. And the Spirit of God moved upon the face of the waters.\"\n            },\n            {\n              \"Verseid\": \"01001003\",\n              \"Verse\": \"And God said, Let there be light: and there was light.\"\n            },\n            {\n              \"Verseid\": \"01001004\",\n              \"Verse\": \"And God saw the light, that it was good: and God divided the light from the darkness.\"\n            },\n            {\n              \"Verseid\": \"01001005\",\n              \"Verse\": \"And God called the light Day, and the darkness he called Night. And the evening and the morning were the first day.\"\n            },\n            {\n              \"Verseid\": \"01001006\",\n              \"Verse\": \"And God said, Let there be a firmament in the midst of the waters, and let it divide the waters from the waters.\"\n            },\n            {\n              \"Verseid\": \"01001007\",\n              \"Verse\": \"And God made the firmament, and divided the waters which were under the firmament from the waters which were above the firmament: and it was so.\"\n            },\n            {\n              \"Verseid\": \"01001008\",\n              \"Verse\": \"And God called the firmament Heaven. And the evening and the morning were the second day.\"\n            },\n            {\n              \"Verseid\": \"01001009\",\n              \"Verse\": \"And God said, Let the waters under the heaven be gathered together unto one place, and let the dry land appear: and it was so.\"\n            },\n            {\n              \"Verseid\": \"01001010\",\n              \"Verse\": \"And God called the dry land Earth; and the gathering together of the waters called he Seas: and God saw that it was good.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01002001\",\n              \"Verse\": \"Thus the heavens and the earth were finished, and all the host of them.\"\n            },\n            {\n              \"Verseid\": \"01002002\",\n              \"Verse\": \"And on the seventh day God ended his work which he had made; and he rested on the seventh day from all his work which he had made.\"\n            },\n            {\n              \"Verseid\": \"01002003\",\n              \"Verse\": \"And God blessed the seventh day, and sanctified it: because that in it he had rested from all his work which God created and made.\"\n            },\n            {\n              \"Verseid\": \"01002004\",\n              \"Verse\": \"These are the generations of the heavens and of the earth when they were created, in the day that the LORD God made the earth and the heavens.\"\n            },\n            {\n              \"Verseid\": \"01002005\",\n              \"Verse\": \"And every plant of the field before it was in the earth, and every herb of the field before it grew: for the LORD God had not caused it to rain upon the earth.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19001001\",\n              \"Verse\": \"Blessed is the man that walketh not in the counsel of the ungodly, nor standeth in the way of sinners, nor sitteth in the seat of the scornful.\"\n            },\n            {\n              \"Verseid\": \"19001002\",\n              \"Verse\": \"But his delight is in the law of the LORD; and in his law doth he meditate day and night.\"\n            },\n            {\n              \"Verseid\": \"19001003\",\n              \"Verse\": \"And he shall be like a tree planted by the rivers of water, that bringeth forth his fruit in his season; his leaf also shall not wither; and whatsoever he doeth shall prosper.\"\n            },\n            {\n              \"Verseid\": \"19001004\",\n              \"Verse\": \"The ungodly are not so: but are like the chaff which the wind driveth away.\"\n            },\n            {\n              \"Verseid\": \"19001005\",\n              \"Verse\": \"Therefore the ungodly shall not stand in the judgment, nor sinners in the congregation of the righteous.\"\n            },\n            {\n              \"Verseid\": \"19001006\",\n              \"Verse\": \"For the LORD knoweth the way of the righteous: but the way of the ungodly shall perish.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19023001\",\n              \"Verse\": \"The LORD is my shepherd; I shall not want.\"\n            },\n            {\n              \"Verseid\": \"19023002\",\n              \"Verse\": \"He maketh me to lie down in green pastures: he leadeth me beside the still waters.\"\n            },\n            {\n              \"Verseid\": \"19023003\",\n              \"Verse\": \"He restoreth my soul: he leadeth me in the paths of righteousness for his name's sake.\"\n            },\n            {\n              \"Verseid\": \"19023004\",\n              \"Verse\": \"Yea, though I walk through the valley of the shadow of death, I will fear no evil: for thou art with me; thy rod and thy staff they comfort me.\"\n            },\n            {\n              \"Verseid\": \"19023005\",\n              \"Verse\": \"Thou preparest a table before me in the presence of mine enemies: thou anointest my head with oil; my cup runneth over.\"\n            },\n            {\n              \"Verseid\": \"19023006\",\n              \"Verse\": \"Surely goodness and mercy shall follow me all the days of my life: and I will dwell in the house of the LORD for ever.\"\n            }\n          ]\n        }\n      ]\n    }\n  ]\n};\n});","lineCount":138,"map":[[138,3]],"functionMap":null},"type":"js/module"}]}