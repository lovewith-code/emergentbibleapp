{"dependencies":[],"output":[{"data":{"code":"__d(function(global, require, _importDefaultUnused, _importAllUnused, module, exports, _dependencyMapUnused) {\n  module.exports = {\n  \"Book\": [\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01001001\",\n              \"Verse\": \"In the beginning God created the heaven and the earth.\"\n            },\n            {\n              \"Verseid\": \"01001002\",\n              \"Verse\": \"And the earth was without form, and void; and darkness was upon the face of the deep.\"\n            },\n            {\n              \"Verseid\": \"01001003\",\n              \"Verse\": \"And God said, Let there be light: and there was light.\"\n            },\n            {\n              \"Verseid\": \"01001004\",\n              \"Verse\": \"And God saw the light, that it was good: and God divided the light from the darkness.\"\n            },\n            {\n              \"Verseid\": \"01001005\",\n              \"Verse\": \"And God called the light Day, and the darkness he called Night.\"\n            },\n            {\n              \"Verseid\": \"01001006\",\n              \"Verse\": \"And God said, Let there be a firmament in the midst of the waters.\"\n            },\n            {\n              \"Verseid\": \"01001007\",\n              \"Verse\": \"And God made the firmament, and divided the waters which were under the firmament from the waters which were above the firmament.\"\n            },\n            {\n              \"Verseid\": \"01001008\",\n              \"Verse\": \"And God called the firmament Heaven. And the evening and the morning were the second day.\"\n            },\n            {\n              \"Verseid\": \"01001009\",\n              \"Verse\": \"And God said, Let the waters under the heaven be gathered together unto one place.\"\n            },\n            {\n              \"Verseid\": \"01001010\",\n              \"Verse\": \"And God called the dry land Earth; and the gathering together of the waters called he Seas.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01002001\",\n              \"Verse\": \"Thus the heavens and the earth were finished, and all the host of them.\"\n            },\n            {\n              \"Verseid\": \"01002002\",\n              \"Verse\": \"And on the seventh day God ended his work which he had made.\"\n            },\n            {\n              \"Verseid\": \"01002003\",\n              \"Verse\": \"And God blessed the seventh day, and sanctified it.\"\n            },\n            {\n              \"Verseid\": \"01002004\",\n              \"Verse\": \"These are the generations of the heavens and of the earth when they were created.\"\n            },\n            {\n              \"Verseid\": \"01002005\",\n              \"Verse\": \"And every plant of the field before it was in the earth, and every herb of the field before it grew.\"\n            },\n            {\n              \"Verseid\": \"01002006\",\n              \"Verse\": \"But there went up a mist from the earth, and watered the whole face of the ground.\"\n            },\n            {\n              \"Verseid\": \"01002007\",\n              \"Verse\": \"And the LORD God formed man of the dust of the ground, and breathed into his nostrils the breath of life.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01003001\",\n              \"Verse\": \"Now the serpent was more subtil than any beast of the field which the LORD God had made.\"\n            },\n            {\n              \"Verseid\": \"01003002\",\n              \"Verse\": \"And the woman said unto the serpent, We may eat of the fruit of the trees of the garden.\"\n            },\n            {\n              \"Verseid\": \"01003003\",\n              \"Verse\": \"But of the fruit of the tree which is in the midst of the garden, God hath said, Ye shall not eat of it.\"\n            },\n            {\n              \"Verseid\": \"01003004\",\n              \"Verse\": \"And the serpent said unto the woman, Ye shall not surely die.\"\n            },\n            {\n              \"Verseid\": \"01003005\",\n              \"Verse\": \"For God doth know that in the day ye eat thereof, then your eyes shall be opened.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"02001001\",\n              \"Verse\": \"Now these are the names of the children of Israel, which came into Egypt.\"\n            },\n            {\n              \"Verseid\": \"02001002\",\n              \"Verse\": \"Reuben, Simeon, Levi, and Judah.\"\n            },\n            {\n              \"Verseid\": \"02001003\",\n              \"Verse\": \"Issachar, Zebulun, and Benjamin.\"\n            },\n            {\n              \"Verseid\": \"02001004\",\n              \"Verse\": \"Dan, and Naphtali, Gad, and Asher.\"\n            },\n            {\n              \"Verseid\": \"02001005\",\n              \"Verse\": \"And all the souls that came out of the loins of Jacob were seventy souls.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"03001001\",\n              \"Verse\": \"And the LORD called unto Moses, and spake unto him out of the tabernacle of the congregation.\"\n            },\n            {\n              \"Verseid\": \"03001002\",\n              \"Verse\": \"Speak unto the children of Israel, and say unto them.\"\n            },\n            {\n              \"Verseid\": \"03001003\",\n              \"Verse\": \"If his offering be a burnt sacrifice of the herd, let him offer a male without blemish.\"\n            },\n            {\n              \"Verseid\": \"03001004\",\n              \"Verse\": \"And he shall put his hand upon the head of the burnt offering; and it shall be accepted for him.\"\n            },\n            {\n              \"Verseid\": \"03001005\",\n              \"Verse\": \"And he shall kill the bullock before the LORD.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"04001001\",\n              \"Verse\": \"And the LORD spake unto Moses in the wilderness of Sinai.\"\n            },\n            {\n              \"Verseid\": \"04001002\",\n              \"Verse\": \"Take ye the sum of all the congregation of the children of Israel.\"\n            },\n            {\n              \"Verseid\": \"04001003\",\n              \"Verse\": \"From twenty years old and upward, all that are able to go forth to war in Israel.\"\n            },\n            {\n              \"Verseid\": \"04001004\",\n              \"Verse\": \"And with you there shall be a man of every tribe.\"\n            },\n            {\n              \"Verseid\": \"04001005\",\n              \"Verse\": \"These are the names of the men that shall stand with you.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"05001001\",\n              \"Verse\": \"These be the words which Moses spake unto all Israel on this side Jordan in the wilderness.\"\n            },\n            {\n              \"Verseid\": \"05001002\",\n              \"Verse\": \"There are eleven days journey from Horeb by the way of mount Seir unto Kadeshbarnea.\"\n            },\n            {\n              \"Verseid\": \"05001003\",\n              \"Verse\": \"And it came to pass in the fortieth year, in the eleventh month.\"\n            },\n            {\n              \"Verseid\": \"05001004\",\n              \"Verse\": \"After he had slain Sihon the king of the Amorites.\"\n            },\n            {\n              \"Verseid\": \"05001005\",\n              \"Verse\": \"On this side Jordan, in the land of Moab, began Moses to declare this law.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"06001001\",\n              \"Verse\": \"After the death of Moses the servant of the LORD it came to pass.\"\n            },\n            {\n              \"Verseid\": \"06001002\",\n              \"Verse\": \"Moses my servant is dead; now therefore arise, go over this Jordan.\"\n            },\n            {\n              \"Verseid\": \"06001003\",\n              \"Verse\": \"Every place that the sole of your foot shall tread upon, that have I given unto you.\"\n            },\n            {\n              \"Verseid\": \"06001004\",\n              \"Verse\": \"Be strong and of a good courage.\"\n            },\n            {\n              \"Verseid\": \"06001005\",\n              \"Verse\": \"Have not I commanded thee? Be strong and of a good courage; be not afraid.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"07001001\",\n              \"Verse\": \"Now after the death of Joshua it came to pass.\"\n            },\n            {\n              \"Verseid\": \"07001002\",\n              \"Verse\": \"And Judah said unto Simeon his brother, Come up with me into my lot.\"\n            },\n            {\n              \"Verseid\": \"07001003\",\n              \"Verse\": \"And the LORD was with Judah; and he drave out the inhabitants of the mountain.\"\n            },\n            {\n              \"Verseid\": \"07001004\",\n              \"Verse\": \"And Caleb said, He that smiteth Kirjathsepher, and taketh it.\"\n            },\n            {\n              \"Verseid\": \"07001005\",\n              \"Verse\": \"And Othniel the son of Kenaz took it.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"08001001\",\n              \"Verse\": \"Now it came to pass in the days when the judges ruled, that there was a famine in the land.\"\n            },\n            {\n              \"Verseid\": \"08001002\",\n              \"Verse\": \"And a certain man of Bethlehemjudah went to sojourn in the country of Moab.\"\n            },\n            {\n              \"Verseid\": \"08001003\",\n              \"Verse\": \"And the name of the man was Elimelech, and the name of his wife Naomi.\"\n            },\n            {\n              \"Verseid\": \"08001004\",\n              \"Verse\": \"And they came into the country of Moab, and continued there.\"\n            },\n            {\n              \"Verseid\": \"08001005\",\n              \"Verse\": \"And Mahlon and Chilion died also both of them.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"09001001\",\n              \"Verse\": \"Now there was a certain man of Ramathaimzophim.\"\n            },\n            {\n              \"Verseid\": \"09001002\",\n              \"Verse\": \"And he had two wives; the name of the one was Hannah.\"\n            },\n            {\n              \"Verseid\": \"09001003\",\n              \"Verse\": \"And this man went up out of his city yearly to worship the LORD of hosts in Shiloh.\"\n            },\n            {\n              \"Verseid\": \"09001004\",\n              \"Verse\": \"And her adversary also provoked her sore.\"\n            },\n            {\n              \"Verseid\": \"09001005\",\n              \"Verse\": \"But unto Hannah he gave a worthy portion; for he loved Hannah.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"10001001\",\n              \"Verse\": \"Now it came to pass after the death of Saul.\"\n            },\n            {\n              \"Verseid\": \"10001002\",\n              \"Verse\": \"David enquired of the LORD, saying, Shall I go up into any of the cities of Judah?\"\n            },\n            {\n              \"Verseid\": \"10001003\",\n              \"Verse\": \"And the LORD said unto him, Go up. And David said, Whither shall I go up?\"\n            },\n            {\n              \"Verseid\": \"10001004\",\n              \"Verse\": \"So David went up thither, and his two wives also.\"\n            },\n            {\n              \"Verseid\": \"10001005\",\n              \"Verse\": \"And the men of Judah came, and there they anointed David king over the house of Judah.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"11001001\",\n              \"Verse\": \"Now king David was old and stricken in years.\"\n            },\n            {\n              \"Verseid\": \"11001002\",\n              \"Verse\": \"His servants said unto him, Let there be sought for my lord the king a young virgin.\"\n            },\n            {\n              \"Verseid\": \"11001003\",\n              \"Verse\": \"So they sought for a fair damsel throughout all the coasts of Israel.\"\n            },\n            {\n              \"Verseid\": \"11001004\",\n              \"Verse\": \"And the damsel was very fair, and cherished the king.\"\n            },\n            {\n              \"Verseid\": \"11001005\",\n              \"Verse\": \"And Adonijah the son of Haggith exalted himself, saying, I will be king.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"12001001\",\n              \"Verse\": \"Then Moab rebelled against Israel after the death of Ahab.\"\n            },\n            {\n              \"Verseid\": \"12001002\",\n              \"Verse\": \"And Ahaziah fell down through a lattice in his upper chamber.\"\n            },\n            {\n              \"Verseid\": \"12001003\",\n              \"Verse\": \"And he sent messengers to inquire of Baalzebub the god of Ekron.\"\n            },\n            {\n              \"Verseid\": \"12001004\",\n              \"Verse\": \"But the angel of the LORD said to Elijah, Arise, go up to meet the messengers.\"\n            },\n            {\n              \"Verseid\": \"12001005\",\n              \"Verse\": \"And Elijah answered, If I be a man of God, let fire come down from heaven.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"13001001\",\n              \"Verse\": \"Adam, Sheth, Enosh.\"\n            },\n            {\n              \"Verseid\": \"13001002\",\n              \"Verse\": \"Kenan, Mahalaleel, Jered.\"\n            },\n            {\n              \"Verseid\": \"13001003\",\n              \"Verse\": \"Henoch, Methuselah, Lamech.\"\n            },\n            {\n              \"Verseid\": \"13001004\",\n              \"Verse\": \"Noah, Shem, Ham, and Japheth.\"\n            },\n            {\n              \"Verseid\": \"13001005\",\n              \"Verse\": \"The sons of Japheth; Gomer, and Magog, and Madai, and Javan.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"14001001\",\n              \"Verse\": \"And Solomon the son of David was strengthened in his kingdom.\"\n            },\n            {\n              \"Verseid\": \"14001002\",\n              \"Verse\": \"Then Solomon spake unto all Israel, to the captains of thousands.\"\n            },\n            {\n              \"Verseid\": \"14001003\",\n              \"Verse\": \"So Solomon, and all the congregation with him, went to the high place.\"\n            },\n            {\n              \"Verseid\": \"14001004\",\n              \"Verse\": \"In that night did God appear unto Solomon.\"\n            },\n            {\n              \"Verseid\": \"14001005\",\n              \"Verse\": \"And Solomon said unto God, Thou hast shewed great mercy unto David my father.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"15001001\",\n              \"Verse\": \"Now in the first year of Cyrus king of Persia.\"\n            },\n            {\n              \"Verseid\": \"15001002\",\n              \"Verse\": \"The LORD stirred up the spirit of Cyrus king of Persia.\"\n            },\n            {\n              \"Verseid\": \"15001003\",\n              \"Verse\": \"Thus saith Cyrus king of Persia, The LORD God of heaven hath given me all the kingdoms.\"\n            },\n            {\n              \"Verseid\": \"15001004\",\n              \"Verse\": \"Who is there among you of all his people? His God be with him.\"\n            },\n            {\n              \"Verseid\": \"15001005\",\n              \"Verse\": \"Then rose up the chief of the fathers of Judah and Benjamin.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"16001001\",\n              \"Verse\": \"The words of Nehemiah the son of Hachaliah.\"\n            },\n            {\n              \"Verseid\": \"16001002\",\n              \"Verse\": \"And it came to pass, when I heard these words, I sat down and wept.\"\n            },\n            {\n              \"Verseid\": \"16001003\",\n              \"Verse\": \"And said, I beseech thee, O LORD God of heaven.\"\n            },\n            {\n              \"Verseid\": \"16001004\",\n              \"Verse\": \"The great and terrible God, that keepeth covenant and mercy.\"\n            },\n            {\n              \"Verseid\": \"16001005\",\n              \"Verse\": \"Let thine ear now be attentive, and thine eyes open.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"17001001\",\n              \"Verse\": \"Now it came to pass in the days of Ahasuerus.\"\n            },\n            {\n              \"Verseid\": \"17001002\",\n              \"Verse\": \"That in those days, when the king Ahasuerus sat on the throne.\"\n            },\n            {\n              \"Verseid\": \"17001003\",\n              \"Verse\": \"In the third year of his reign, he made a feast unto all his princes.\"\n            },\n            {\n              \"Verseid\": \"17001004\",\n              \"Verse\": \"Also Vashti the queen made a feast for the women.\"\n            },\n            {\n              \"Verseid\": \"17001005\",\n              \"Verse\": \"On the seventh day, the heart of the king was merry with wine.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"18001001\",\n              \"Verse\": \"There was a man in the land of Uz, whose name was Job.\"\n            },\n            {\n              \"Verseid\": \"18001002\",\n              \"Verse\": \"And that man was perfect and upright, and one that feared God.\"\n            },\n            {\n              \"Verseid\": \"18001003\",\n              \"Verse\": \"His substance also was seven thousand sheep, and three thousand camels.\"\n            },\n            {\n              \"Verseid\": \"18001004\",\n              \"Verse\": \"And his sons went and feasted in their houses.\"\n            },\n            {\n              \"Verseid\": \"18001005\",\n              \"Verse\": \"And Job sent and sanctified them, and rose up early in the morning.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19001001\",\n              \"Verse\": \"Blessed is the man that walketh not in the counsel of the ungodly.\"\n            },\n            {\n              \"Verseid\": \"19001002\",\n              \"Verse\": \"But his delight is in the law of the LORD; and in his law doth he meditate day and night.\"\n            },\n            {\n              \"Verseid\": \"19001003\",\n              \"Verse\": \"And he shall be like a tree planted by the rivers of water.\"\n            },\n            {\n              \"Verseid\": \"19001004\",\n              \"Verse\": \"The ungodly are not so: but are like the chaff which the wind driveth away.\"\n            },\n            {\n              \"Verseid\": \"19001005\",\n              \"Verse\": \"Therefore the ungodly shall not stand in the judgment.\"\n            },\n            {\n              \"Verseid\": \"19001006\",\n              \"Verse\": \"For the LORD knoweth the way of the righteous: but the way of the ungodly shall perish.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19002001\",\n              \"Verse\": \"The LORD is my shepherd; I shall not want.\"\n            },\n            {\n              \"Verseid\": \"19002002\",\n              \"Verse\": \"He maketh me to lie down in green pastures: he leadeth me beside the still waters.\"\n            },\n            {\n              \"Verseid\": \"19002003\",\n              \"Verse\": \"He restoreth my soul: he leadeth me in the paths of righteousness for his name's sake.\"\n            },\n            {\n              \"Verseid\": \"19002004\",\n              \"Verse\": \"Yea, though I walk through the valley of the shadow of death, I will fear no evil.\"\n            },\n            {\n              \"Verseid\": \"19002005\",\n              \"Verse\": \"Thou preparest a table before me in the presence of mine enemies.\"\n            },\n            {\n              \"Verseid\": \"19002006\",\n              \"Verse\": \"Surely goodness and mercy shall follow me all the days of my life.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19003001\",\n              \"Verse\": \"The LORD is my light and my salvation; whom shall I fear?\"\n            },\n            {\n              \"Verseid\": \"19003002\",\n              \"Verse\": \"When the wicked came upon me to eat up my flesh, my enemies and my foes, they stumbled.\"\n            },\n            {\n              \"Verseid\": \"19003003\",\n              \"Verse\": \"Though an host should encamp against me, my heart shall not fear.\"\n            },\n            {\n              \"Verseid\": \"19003004\",\n              \"Verse\": \"One thing have I desired of the LORD, that will I seek after.\"\n            },\n            {\n              \"Verseid\": \"19003005\",\n              \"Verse\": \"For in the time of trouble he shall hide me in his pavilion.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"20001001\",\n              \"Verse\": \"The proverbs of Solomon the son of David, king of Israel.\"\n            },\n            {\n              \"Verseid\": \"20001002\",\n              \"Verse\": \"To know wisdom and instruction; to perceive the words of understanding.\"\n            },\n            {\n              \"Verseid\": \"20001003\",\n              \"Verse\": \"To receive the instruction of wisdom, justice, and judgment, and equity.\"\n            },\n            {\n              \"Verseid\": \"20001004\",\n              \"Verse\": \"To give subtilty to the simple, to the young man knowledge and discretion.\"\n            },\n            {\n              \"Verseid\": \"20001005\",\n              \"Verse\": \"The fear of the LORD is the beginning of knowledge.\"\n            },\n            {\n              \"Verseid\": \"20001006\",\n              \"Verse\": \"My son, hear the instruction of thy father, and forsake not the law of thy mother.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"21001001\",\n              \"Verse\": \"The words of the Preacher, the son of David, king in Jerusalem.\"\n            },\n            {\n              \"Verseid\": \"21001002\",\n              \"Verse\": \"Vanity of vanities, saith the Preacher, vanity of vanities; all is vanity.\"\n            },\n            {\n              \"Verseid\": \"21001003\",\n              \"Verse\": \"What profit hath a man of all his labour which he taketh under the sun?\"\n            },\n            {\n              \"Verseid\": \"21001004\",\n              \"Verse\": \"One generation passeth away, and another generation cometh.\"\n            },\n            {\n              \"Verseid\": \"21001005\",\n              \"Verse\": \"The sun also ariseth, and the sun goeth down.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"22001001\",\n              \"Verse\": \"The song of songs, which is Solomon's.\"\n            },\n            {\n              \"Verseid\": \"22001002\",\n              \"Verse\": \"Let him kiss me with the kisses of his mouth.\"\n            },\n            {\n              \"Verseid\": \"22001003\",\n              \"Verse\": \"Draw me, we will run after thee.\"\n            },\n            {\n              \"Verseid\": \"22001004\",\n              \"Verse\": \"I am black, but comely, O ye daughters of Jerusalem.\"\n            },\n            {\n              \"Verseid\": \"22001005\",\n              \"Verse\": \"Look not upon me, because I am black.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"23001001\",\n              \"Verse\": \"The vision of Isaiah the son of Amoz, which he saw concerning Judah and Jerusalem.\"\n            },\n            {\n              \"Verseid\": \"23001002\",\n              \"Verse\": \"Hear, O heavens, and give ear, O earth: for the LORD hath spoken.\"\n            },\n            {\n              \"Verseid\": \"23001003\",\n              \"Verse\": \"I have nourished and brought up children, and they have rebelled against me.\"\n            },\n            {\n              \"Verseid\": \"23001004\",\n              \"Verse\": \"The ox knoweth his owner, and the donkey his master's crib.\"\n            },\n            {\n              \"Verseid\": \"23001005\",\n              \"Verse\": \"Ah sinful nation, a people laden with iniquity.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"24001001\",\n              \"Verse\": \"The words of Jeremiah the son of Hilkiah.\"\n            },\n            {\n              \"Verseid\": \"24001002\",\n              \"Verse\": \"Then the word of the LORD came unto me, saying.\"\n            },\n            {\n              \"Verseid\": \"24001003\",\n              \"Verse\": \"Before I formed thee in the belly I knew thee.\"\n            },\n            {\n              \"Verseid\": \"24001004\",\n              \"Verse\": \"Then said I, Ah, Lord GOD! behold, I cannot speak: for I am a child.\"\n            },\n            {\n              \"Verseid\": \"24001005\",\n              \"Verse\": \"But the LORD said unto me, Say not, I am a child.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"25001001\",\n              \"Verse\": \"How doth the city sit solitary, that was full of people!\"\n            },\n            {\n              \"Verseid\": \"25001002\",\n              \"Verse\": \"She weepeth sore in the night, and her tears are on her cheeks.\"\n            },\n            {\n              \"Verseid\": \"25001003\",\n              \"Verse\": \"Judah is gone into captivity because of affliction.\"\n            },\n            {\n              \"Verseid\": \"25001004\",\n              \"Verse\": \"The ways of Zion do mourn, because none come to the solemn feasts.\"\n            },\n            {\n              \"Verseid\": \"25001005\",\n              \"Verse\": \"Her adversaries are the chief, her enemies prosper.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"26001001\",\n              \"Verse\": \"Now it came to pass in the thirtieth year.\"\n            },\n            {\n              \"Verseid\": \"26001002\",\n              \"Verse\": \"The heavens were opened, and I saw visions of God.\"\n            },\n            {\n              \"Verseid\": \"26001003\",\n              \"Verse\": \"The word of the LORD came expressly unto Ezekiel the priest.\"\n            },\n            {\n              \"Verseid\": \"26001004\",\n              \"Verse\": \"And I looked, and behold, a whirlwind came out of the north.\"\n            },\n            {\n              \"Verseid\": \"26001005\",\n              \"Verse\": \"Also out of the midst thereof came the likeness of four living creatures.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"27001001\",\n              \"Verse\": \"In the third year of the reign of Jehoiakim king of Judah.\"\n            },\n            {\n              \"Verseid\": \"27001002\",\n              \"Verse\": \"And the Lord gave Jehoiakim king of Judah into his hand.\"\n            },\n            {\n              \"Verseid\": \"27001003\",\n              \"Verse\": \"And the king spake unto Ashpenaz the master of his eunuchs.\"\n            },\n            {\n              \"Verseid\": \"27001004\",\n              \"Verse\": \"Children in whom was no blemish, but well favoured.\"\n            },\n            {\n              \"Verseid\": \"27001005\",\n              \"Verse\": \"Daniel purposed in his heart that he would not defile himself.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"28001001\",\n              \"Verse\": \"The word of the LORD that came unto Hosea.\"\n            },\n            {\n              \"Verseid\": \"28001002\",\n              \"Verse\": \"Go, take unto thee a wife.\"\n            },\n            {\n              \"Verseid\": \"28001003\",\n              \"Verse\": \"So he went and took Gomer the daughter of Diblaim.\"\n            },\n            {\n              \"Verseid\": \"28001004\",\n              \"Verse\": \"And the LORD said unto him, Call his name Jezreel.\"\n            },\n            {\n              \"Verseid\": \"28001005\",\n              \"Verse\": \"Yet the number of the children of Israel shall be as the sand of the sea.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"29001001\",\n              \"Verse\": \"The word of the LORD that came to Joel the son of Pethuel.\"\n            },\n            {\n              \"Verseid\": \"29001002\",\n              \"Verse\": \"Hear this, ye old men, and give ear.\"\n            },\n            {\n              \"Verseid\": \"29001003\",\n              \"Verse\": \"That which the palmerworm hath left hath the locust eaten.\"\n            },\n            {\n              \"Verseid\": \"29001004\",\n              \"Verse\": \"Awake, ye drunkards, and weep.\"\n            },\n            {\n              \"Verseid\": \"29001005\",\n              \"Verse\": \"For a nation is come up upon my land.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"30001001\",\n              \"Verse\": \"The words of Amos, who was among the herdmen of Tekoa.\"\n            },\n            {\n              \"Verseid\": \"30001002\",\n              \"Verse\": \"And he said, The LORD will roar from Zion.\"\n            },\n            {\n              \"Verseid\": \"30001003\",\n              \"Verse\": \"For three transgressions of Damascus, and for four.\"\n            },\n            {\n              \"Verseid\": \"30001004\",\n              \"Verse\": \"Thus saith the LORD; For three transgressions of Gaza.\"\n            },\n            {\n              \"Verseid\": \"30001005\",\n              \"Verse\": \"But I will send a fire on the wall of Gaza.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"31001001\",\n              \"Verse\": \"The vision of Obadiah. Thus saith the Lord GOD concerning Edom.\"\n            },\n            {\n              \"Verseid\": \"31001002\",\n              \"Verse\": \"Behold, I have made thee small among the heathen.\"\n            },\n            {\n              \"Verseid\": \"31001003\",\n              \"Verse\": \"The pride of thine heart hath deceived thee.\"\n            },\n            {\n              \"Verseid\": \"31001004\",\n              \"Verse\": \"Though thou exalt thyself as the eagle.\"\n            },\n            {\n              \"Verseid\": \"31001005\",\n              \"Verse\": \"Shall I not in that day destroy the wise men out of Edom?\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"32001001\",\n              \"Verse\": \"Now the word of the LORD came unto Jonah the son of Amittai.\"\n            },\n            {\n              \"Verseid\": \"32001002\",\n              \"Verse\": \"Arise, go to Nineveh, that great city.\"\n            },\n            {\n              \"Verseid\": \"32001003\",\n              \"Verse\": \"But Jonah rose up to flee unto Tarshish.\"\n            },\n            {\n              \"Verseid\": \"32001004\",\n              \"Verse\": \"But the LORD sent out a great wind into the sea.\"\n            },\n            {\n              \"Verseid\": \"32001005\",\n              \"Verse\": \"Then the mariners were afraid, and cried every man unto his god.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"33001001\",\n              \"Verse\": \"The word of the LORD that came to Micah.\"\n            },\n            {\n              \"Verseid\": \"33001002\",\n              \"Verse\": \"Hear, all ye people; hearken, O earth.\"\n            },\n            {\n              \"Verseid\": \"33001003\",\n              \"Verse\": \"For, behold, the LORD cometh forth out of his place.\"\n            },\n            {\n              \"Verseid\": \"33001004\",\n              \"Verse\": \"And the mountains shall be molten under him.\"\n            },\n            {\n              \"Verseid\": \"33001005\",\n              \"Verse\": \"For the transgression of Jacob is all this.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"34001001\",\n              \"Verse\": \"The burden of Nineveh. The book of the vision of Nahum.\"\n            },\n            {\n              \"Verseid\": \"34001002\",\n              \"Verse\": \"God is jealous, and the LORD revengeth.\"\n            },\n            {\n              \"Verseid\": \"34001003\",\n              \"Verse\": \"The LORD is slow to anger, and great in power.\"\n            },\n            {\n              \"Verseid\": \"34001004\",\n              \"Verse\": \"He rebuketh the sea, and maketh it dry.\"\n            },\n            {\n              \"Verseid\": \"34001005\",\n              \"Verse\": \"The mountains quake at him, and the hills melt.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"35001001\",\n              \"Verse\": \"The burden which Habakkuk the prophet did see.\"\n            },\n            {\n              \"Verseid\": \"35001002\",\n              \"Verse\": \"O LORD, how long shall I cry, and thou wilt not hear!\"\n            },\n            {\n              \"Verseid\": \"35001003\",\n              \"Verse\": \"Why dost thou shew me iniquity, and cause me to behold grievance?\"\n            },\n            {\n              \"Verseid\": \"35001004\",\n              \"Verse\": \"Therefore the law is slacked, and judgment doth never go forth.\"\n            },\n            {\n              \"Verseid\": \"35001005\",\n              \"Verse\": \"Behold ye among the heathen, and regard, and wonder marvellously.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"36001001\",\n              \"Verse\": \"The word of the LORD which came unto Zephaniah.\"\n            },\n            {\n              \"Verseid\": \"36001002\",\n              \"Verse\": \"I will utterly consume all things from off the land.\"\n            },\n            {\n              \"Verseid\": \"36001003\",\n              \"Verse\": \"I will consume man and beast.\"\n            },\n            {\n              \"Verseid\": \"36001004\",\n              \"Verse\": \"I will also stretch out mine hand upon Judah.\"\n            },\n            {\n              \"Verseid\": \"36001005\",\n              \"Verse\": \"And them that worship the host of heaven upon the housetops.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"37001001\",\n              \"Verse\": \"In the second year of Darius the king.\"\n            },\n            {\n              \"Verseid\": \"37001002\",\n              \"Verse\": \"Thus speaketh the LORD of hosts.\"\n            },\n            {\n              \"Verseid\": \"37001003\",\n              \"Verse\": \"Is it time for you to dwell in your cieled houses?\"\n            },\n            {\n              \"Verseid\": \"37001004\",\n              \"Verse\": \"Ye have sown much, and bring in little.\"\n            },\n            {\n              \"Verseid\": \"37001005\",\n              \"Verse\": \"Thus saith the LORD of hosts; Consider your ways.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"38001001\",\n              \"Verse\": \"In the eighth month, in the second year of Darius.\"\n            },\n            {\n              \"Verseid\": \"38001002\",\n              \"Verse\": \"The LORD hath been sore displeased with your fathers.\"\n            },\n            {\n              \"Verseid\": \"38001003\",\n              \"Verse\": \"Therefore say thou unto them, Thus saith the LORD of hosts.\"\n            },\n            {\n              \"Verseid\": \"38001004\",\n              \"Verse\": \"Turn ye unto me, saith the LORD of hosts.\"\n            },\n            {\n              \"Verseid\": \"38001005\",\n              \"Verse\": \"Be ye not as your fathers.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"39001001\",\n              \"Verse\": \"The burden of the word of the LORD to Israel by Malachi.\"\n            },\n            {\n              \"Verseid\": \"39001002\",\n              \"Verse\": \"I have loved you, saith the LORD.\"\n            },\n            {\n              \"Verseid\": \"39001003\",\n              \"Verse\": \"Was not Esau Jacob's brother? saith the LORD.\"\n            },\n            {\n              \"Verseid\": \"39001004\",\n              \"Verse\": \"Yet I loved Jacob, and I hated Esau.\"\n            },\n            {\n              \"Verseid\": \"39001005\",\n              \"Verse\": \"And I laid his mountains and his heritage waste.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"40001001\",\n              \"Verse\": \"The book of the generation of Jesus Christ, the son of David, the son of Abraham.\"\n            },\n            {\n              \"Verseid\": \"40001002\",\n              \"Verse\": \"Abraham begat Isaac; and Isaac begat Jacob; and Jacob begat Judas and his brethren.\"\n            },\n            {\n              \"Verseid\": \"40001003\",\n              \"Verse\": \"And Judas begat Phares and Zara of Thamar.\"\n            },\n            {\n              \"Verseid\": \"40001004\",\n              \"Verse\": \"And Aram begat Aminadab; and Aminadab begat Naasson.\"\n            },\n            {\n              \"Verseid\": \"40001005\",\n              \"Verse\": \"And Salmon begat Booz of Rachab; and Booz begat Obed of Ruth.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"40002001\",\n              \"Verse\": \"Now when Jesus was born in Bethlehem of Judaea in the days of Herod the king.\"\n            },\n            {\n              \"Verseid\": \"40002002\",\n              \"Verse\": \"Where is he that is born King of the Jews?\"\n            },\n            {\n              \"Verseid\": \"40002003\",\n              \"Verse\": \"When Herod the king had heard these things, he was troubled.\"\n            },\n            {\n              \"Verseid\": \"40002004\",\n              \"Verse\": \"And when he had gathered all the chief priests and scribes of the people together.\"\n            },\n            {\n              \"Verseid\": \"40002005\",\n              \"Verse\": \"And thou Bethlehem, in the land of Juda, art not the least among the princes of Juda.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"41001001\",\n              \"Verse\": \"The beginning of the gospel of Jesus Christ, the Son of God.\"\n            },\n            {\n              \"Verseid\": \"41001002\",\n              \"Verse\": \"As it is written in the prophets, Behold, I send my messenger before thy face.\"\n            },\n            {\n              \"Verseid\": \"41001003\",\n              \"Verse\": \"The voice of one crying in the wilderness, Prepare ye the way of the Lord.\"\n            },\n            {\n              \"Verseid\": \"41001004\",\n              \"Verse\": \"John did baptize in the wilderness, and preach the baptism of repentance.\"\n            },\n            {\n              \"Verseid\": \"41001005\",\n              \"Verse\": \"And there went out unto him all the land of Judaea.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"42001001\",\n              \"Verse\": \"Forasmuch as many have taken in hand to set forth in order a declaration.\"\n            },\n            {\n              \"Verseid\": \"42001002\",\n              \"Verse\": \"It seemed good to me also to write unto thee in order.\"\n            },\n            {\n              \"Verseid\": \"42001003\",\n              \"Verse\": \"There was in the days of Herod, the king of Judaea, a certain priest named Zacharias.\"\n            },\n            {\n              \"Verseid\": \"42001004\",\n              \"Verse\": \"And they were both righteous before God.\"\n            },\n            {\n              \"Verseid\": \"42001005\",\n              \"Verse\": \"And they had no child, because that Elisabeth was barren.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"43001001\",\n              \"Verse\": \"In the beginning was the Word, and the Word was with God, and the Word was God.\"\n            },\n            {\n              \"Verseid\": \"43001002\",\n              \"Verse\": \"The same was in the beginning with God.\"\n            },\n            {\n              \"Verseid\": \"43001003\",\n              \"Verse\": \"All things were made by him; and without him was not any thing made that was made.\"\n            },\n            {\n              \"Verseid\": \"43001004\",\n              \"Verse\": \"In him was life; and the life was the light of men.\"\n            },\n            {\n              \"Verseid\": \"43001005\",\n              \"Verse\": \"And the light shineth in darkness; and the darkness comprehended it not.\"\n            },\n            {\n              \"Verseid\": \"43001006\",\n              \"Verse\": \"There was a man sent from God, whose name was John.\"\n            },\n            {\n              \"Verseid\": \"43001007\",\n              \"Verse\": \"The same came for a witness, to bear witness of the Light.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"44001001\",\n              \"Verse\": \"The former treatise have I made, O Theophilus, of all that Jesus began both to do and teach.\"\n            },\n            {\n              \"Verseid\": \"44001002\",\n              \"Verse\": \"Until the day in which he was taken up.\"\n            },\n            {\n              \"Verseid\": \"44001003\",\n              \"Verse\": \"To whom also he shewed himself alive after his passion.\"\n            },\n            {\n              \"Verseid\": \"44001004\",\n              \"Verse\": \"Being assembled together with them, commanded them that they should not depart from Jerusalem.\"\n            },\n            {\n              \"Verseid\": \"44001005\",\n              \"Verse\": \"For John truly baptized with water; but ye shall be baptized with the Holy Ghost.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"45001001\",\n              \"Verse\": \"Paul, a servant of Jesus Christ, called to be an apostle.\"\n            },\n            {\n              \"Verseid\": \"45001002\",\n              \"Verse\": \"Which he had promised afore by his prophets in the holy scriptures.\"\n            },\n            {\n              \"Verseid\": \"45001003\",\n              \"Verse\": \"Concerning his Son Jesus Christ our Lord.\"\n            },\n            {\n              \"Verseid\": \"45001004\",\n              \"Verse\": \"By whom we have received grace and apostleship.\"\n            },\n            {\n              \"Verseid\": \"45001005\",\n              \"Verse\": \"Among whom are ye also the called of Jesus Christ.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"46001001\",\n              \"Verse\": \"Paul, called to be an apostle of Jesus Christ through the will of God.\"\n            },\n            {\n              \"Verseid\": \"46001002\",\n              \"Verse\": \"Unto the church of God which is at Corinth.\"\n            },\n            {\n              \"Verseid\": \"46001003\",\n              \"Verse\": \"Grace be unto you, and peace, from God our Father.\"\n            },\n            {\n              \"Verseid\": \"46001004\",\n              \"Verse\": \"I thank my God always on your behalf.\"\n            },\n            {\n              \"Verseid\": \"46001005\",\n              \"Verse\": \"That in every thing ye are enriched by him.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"47001001\",\n              \"Verse\": \"Paul, an apostle of Jesus Christ by the will of God.\"\n            },\n            {\n              \"Verseid\": \"47001002\",\n              \"Verse\": \"Grace be to you and peace from God our Father.\"\n            },\n            {\n              \"Verseid\": \"47001003\",\n              \"Verse\": \"Blessed be God, even the Father of our Lord Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"47001004\",\n              \"Verse\": \"Who comforteth us in all our tribulation.\"\n            },\n            {\n              \"Verseid\": \"47001005\",\n              \"Verse\": \"For as the sufferings of Christ abound in us.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"48001001\",\n              \"Verse\": \"Paul, an apostle, not of men, neither by man, but by Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"48001002\",\n              \"Verse\": \"Grace be to you and peace from God the Father.\"\n            },\n            {\n              \"Verseid\": \"48001003\",\n              \"Verse\": \"I marvel that ye are so soon removed.\"\n            },\n            {\n              \"Verseid\": \"48001004\",\n              \"Verse\": \"But though we, or an angel from heaven, preach any other gospel.\"\n            },\n            {\n              \"Verseid\": \"48001005\",\n              \"Verse\": \"For do I now persuade men, or God?\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"49001001\",\n              \"Verse\": \"Paul, an apostle of Jesus Christ by the will of God.\"\n            },\n            {\n              \"Verseid\": \"49001002\",\n              \"Verse\": \"Grace be to you, and peace, from God our Father.\"\n            },\n            {\n              \"Verseid\": \"49001003\",\n              \"Verse\": \"Blessed be the God and Father of our Lord Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"49001004\",\n              \"Verse\": \"Who hath blessed us with all spiritual blessings in heavenly places.\"\n            },\n            {\n              \"Verseid\": \"49001005\",\n              \"Verse\": \"According as he hath chosen us in him before the foundation of the world.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"50001001\",\n              \"Verse\": \"Paul and Timotheus, the servants of Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"50001002\",\n              \"Verse\": \"Grace be unto you, and peace, from God our Father.\"\n            },\n            {\n              \"Verseid\": \"50001003\",\n              \"Verse\": \"I thank my God upon every remembrance of you.\"\n            },\n            {\n              \"Verseid\": \"50001004\",\n              \"Verse\": \"Always in every prayer of mine for you all.\"\n            },\n            {\n              \"Verseid\": \"50001005\",\n              \"Verse\": \"For your fellowship in the gospel from the first day until now.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"51001001\",\n              \"Verse\": \"Paul, an apostle of Jesus Christ by the will of God.\"\n            },\n            {\n              \"Verseid\": \"51001002\",\n              \"Verse\": \"Grace be unto you, and peace.\"\n            },\n            {\n              \"Verseid\": \"51001003\",\n              \"Verse\": \"We give thanks to God and the Father of our Lord Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"51001004\",\n              \"Verse\": \"Since we heard of your faith in Christ Jesus.\"\n            },\n            {\n              \"Verseid\": \"51001005\",\n              \"Verse\": \"For the hope which is laid up for you in heaven.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"52001001\",\n              \"Verse\": \"Paul, and Silvanus, and Timotheus, unto the church of the Thessalonians.\"\n            },\n            {\n              \"Verseid\": \"52001002\",\n              \"Verse\": \"Grace be unto you, and peace.\"\n            },\n            {\n              \"Verseid\": \"52001003\",\n              \"Verse\": \"We give thanks to God always for you all.\"\n            },\n            {\n              \"Verseid\": \"52001004\",\n              \"Verse\": \"Remembering without ceasing your work of faith.\"\n            },\n            {\n              \"Verseid\": \"52001005\",\n              \"Verse\": \"For our gospel came not unto you in word only.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"53001001\",\n              \"Verse\": \"Paul, and Silvanus, and Timotheus, unto the church of the Thessalonians.\"\n            },\n            {\n              \"Verseid\": \"53001002\",\n              \"Verse\": \"Grace unto you, and peace.\"\n            },\n            {\n              \"Verseid\": \"53001003\",\n              \"Verse\": \"We are bound to thank God always for you.\"\n            },\n            {\n              \"Verseid\": \"53001004\",\n              \"Verse\": \"So that we ourselves glory in you in the churches of God.\"\n            },\n            {\n              \"Verseid\": \"53001005\",\n              \"Verse\": \"Which is a manifest token of the righteous judgment of God.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"54001001\",\n              \"Verse\": \"Paul, an apostle of Jesus Christ by the commandment of God our Saviour.\"\n            },\n            {\n              \"Verseid\": \"54001002\",\n              \"Verse\": \"Unto Timothy, my own son in the faith.\"\n            },\n            {\n              \"Verseid\": \"54001003\",\n              \"Verse\": \"As I besought thee to abide still at Ephesus.\"\n            },\n            {\n              \"Verseid\": \"54001004\",\n              \"Verse\": \"Neither give heed to fables and endless genealogies.\"\n            },\n            {\n              \"Verseid\": \"54001005\",\n              \"Verse\": \"Now the end of the commandment is charity out of a pure heart.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"55001001\",\n              \"Verse\": \"Paul, an apostle of Jesus Christ by the will of God.\"\n            },\n            {\n              \"Verseid\": \"55001002\",\n              \"Verse\": \"To Timothy, my dearly beloved son.\"\n            },\n            {\n              \"Verseid\": \"55001003\",\n              \"Verse\": \"I thank God, whom I serve from my forefathers with pure conscience.\"\n            },\n            {\n              \"Verseid\": \"55001004\",\n              \"Verse\": \"Greatly desiring to see thee, being mindful of thy tears.\"\n            },\n            {\n              \"Verseid\": \"55001005\",\n              \"Verse\": \"When I call to remembrance the unfeigned faith that is in thee.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"56001001\",\n              \"Verse\": \"Paul, a servant of God, and an apostle of Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"56001002\",\n              \"Verse\": \"In hope of eternal life, which God promised before the world began.\"\n            },\n            {\n              \"Verseid\": \"56001003\",\n              \"Verse\": \"To Titus, mine own son after the common faith.\"\n            },\n            {\n              \"Verseid\": \"56001004\",\n              \"Verse\": \"For this cause left I thee in Crete.\"\n            },\n            {\n              \"Verseid\": \"56001005\",\n              \"Verse\": \"If any be blameless, the husband of one wife.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"57001001\",\n              \"Verse\": \"Paul, a prisoner of Jesus Christ, and Timothy our brother.\"\n            },\n            {\n              \"Verseid\": \"57001002\",\n              \"Verse\": \"Unto Philemon our dearly beloved, and fellowlabourer.\"\n            },\n            {\n              \"Verseid\": \"57001003\",\n              \"Verse\": \"Grace to you, and peace, from God our Father.\"\n            },\n            {\n              \"Verseid\": \"57001004\",\n              \"Verse\": \"I thank my God, making mention of thee always in my prayers.\"\n            },\n            {\n              \"Verseid\": \"57001005\",\n              \"Verse\": \"Hearing of thy love and faith.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"58001001\",\n              \"Verse\": \"God, who at sundry times and in divers manners spake in time past unto the fathers.\"\n            },\n            {\n              \"Verseid\": \"58001002\",\n              \"Verse\": \"Hath in these last days spoken unto us by his Son.\"\n            },\n            {\n              \"Verseid\": \"58001003\",\n              \"Verse\": \"Whom he hath appointed heir of all things.\"\n            },\n            {\n              \"Verseid\": \"58001004\",\n              \"Verse\": \"Who being the brightness of his glory, and the express image of his person.\"\n            },\n            {\n              \"Verseid\": \"58001005\",\n              \"Verse\": \"Being made so much better than the angels.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"59001001\",\n              \"Verse\": \"James, a servant of God and of the Lord Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"59001002\",\n              \"Verse\": \"My brethren, count it all joy when ye fall into divers temptations.\"\n            },\n            {\n              \"Verseid\": \"59001003\",\n              \"Verse\": \"Knowing this, that the trying of your faith worketh patience.\"\n            },\n            {\n              \"Verseid\": \"59001004\",\n              \"Verse\": \"But let patience have her perfect work.\"\n            },\n            {\n              \"Verseid\": \"59001005\",\n              \"Verse\": \"If any of you lack wisdom, let him ask of God.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"60001001\",\n              \"Verse\": \"Peter, an apostle of Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"60001002\",\n              \"Verse\": \"Elect according to the foreknowledge of God the Father.\"\n            },\n            {\n              \"Verseid\": \"60001003\",\n              \"Verse\": \"Grace unto you, and peace, be multiplied.\"\n            },\n            {\n              \"Verseid\": \"60001004\",\n              \"Verse\": \"Blessed be the God and Father of our Lord Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"60001005\",\n              \"Verse\": \"Which according to his abundant mercy hath begotten us again.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"61001001\",\n              \"Verse\": \"Simon Peter, a servant and an apostle of Jesus Christ.\"\n            },\n            {\n              \"Verseid\": \"61001002\",\n              \"Verse\": \"Grace and peace be multiplied unto you.\"\n            },\n            {\n              \"Verseid\": \"61001003\",\n              \"Verse\": \"According as his divine power hath given unto us all things.\"\n            },\n            {\n              \"Verseid\": \"61001004\",\n              \"Verse\": \"Whereby are given unto us exceeding great and precious promises.\"\n            },\n            {\n              \"Verseid\": \"61001005\",\n              \"Verse\": \"And beside this, giving all diligence, add to your faith virtue.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"62001001\",\n              \"Verse\": \"That which was from the beginning, which we have heard.\"\n            },\n            {\n              \"Verseid\": \"62001002\",\n              \"Verse\": \"That which we have seen and heard declare we unto you.\"\n            },\n            {\n              \"Verseid\": \"62001003\",\n              \"Verse\": \"And these things write we unto you, that your joy may be full.\"\n            },\n            {\n              \"Verseid\": \"62001004\",\n              \"Verse\": \"This then is the message which we have heard of him.\"\n            },\n            {\n              \"Verseid\": \"62001005\",\n              \"Verse\": \"God is light, and in him is no darkness at all.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"63001001\",\n              \"Verse\": \"The elder unto the elect lady and her children.\"\n            },\n            {\n              \"Verseid\": \"63001002\",\n              \"Verse\": \"For the truth's sake, which dwelleth in us.\"\n            },\n            {\n              \"Verseid\": \"63001003\",\n              \"Verse\": \"Grace be with you, mercy, and peace.\"\n            },\n            {\n              \"Verseid\": \"63001004\",\n              \"Verse\": \"I rejoiced greatly that I found of thy children walking in truth.\"\n            },\n            {\n              \"Verseid\": \"63001005\",\n              \"Verse\": \"And now I beseech thee, lady, not as though I wrote a new commandment.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"64001001\",\n              \"Verse\": \"The elder unto the wellbeloved Gaius, whom I love in the truth.\"\n            },\n            {\n              \"Verseid\": \"64001002\",\n              \"Verse\": \"Beloved, I wish above all things that thou mayest prosper.\"\n            },\n            {\n              \"Verseid\": \"64001003\",\n              \"Verse\": \"For I rejoiced greatly, when the brethren came and testified of the truth.\"\n            },\n            {\n              \"Verseid\": \"64001004\",\n              \"Verse\": \"I have no greater joy than to hear that my children walk in truth.\"\n            },\n            {\n              \"Verseid\": \"64001005\",\n              \"Verse\": \"Beloved, thou doest faithfully whatsoever thou doest.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"65001001\",\n              \"Verse\": \"Jude, the servant of Jesus Christ, and brother of James.\"\n            },\n            {\n              \"Verseid\": \"65001002\",\n              \"Verse\": \"Mercy unto you, and peace, and love, be multiplied.\"\n            },\n            {\n              \"Verseid\": \"65001003\",\n              \"Verse\": \"Beloved, when I gave all diligence to write unto you of the common salvation.\"\n            },\n            {\n              \"Verseid\": \"65001004\",\n              \"Verse\": \"For there are certain men crept in unawares.\"\n            },\n            {\n              \"Verseid\": \"65001005\",\n              \"Verse\": \"I will therefore put you in remembrance.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"66001001\",\n              \"Verse\": \"The Revelation of Jesus Christ, which God gave unto him.\"\n            },\n            {\n              \"Verseid\": \"66001002\",\n              \"Verse\": \"Blessed is he that readeth, and they that hear the words of this prophecy.\"\n            },\n            {\n              \"Verseid\": \"66001003\",\n              \"Verse\": \"John to the seven churches which are in Asia.\"\n            },\n            {\n              \"Verseid\": \"66001004\",\n              \"Verse\": \"Grace be unto you, and peace, from him which is, and which was, and which is to come.\"\n            },\n            {\n              \"Verseid\": \"66001005\",\n              \"Verse\": \"And from Jesus Christ, who is the faithful witness.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"66002001\",\n              \"Verse\": \"I was in the Spirit on the Lord's day, and heard behind me a great voice.\"\n            },\n            {\n              \"Verseid\": \"66002002\",\n              \"Verse\": \"Saying, I am Alpha and Omega, the first and the last.\"\n            },\n            {\n              \"Verseid\": \"66002003\",\n              \"Verse\": \"And I turned to see the voice that spake with me.\"\n            },\n            {\n              \"Verseid\": \"66002004\",\n              \"Verse\": \"And being turned, I saw seven golden candlesticks.\"\n            },\n            {\n              \"Verseid\": \"66002005\",\n              \"Verse\": \"And in the midst of the seven candlesticks one like unto the Son of man.\"\n            }\n          ]\n        }\n      ]\n    }\n  ]\n};\n});","lineCount":2046,"map":[[2046,3]],"functionMap":null},"type":"js/module"}]}