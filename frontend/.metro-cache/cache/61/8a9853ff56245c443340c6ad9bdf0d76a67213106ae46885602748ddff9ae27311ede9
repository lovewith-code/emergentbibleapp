{"dependencies":[],"output":[{"data":{"code":"__d(function(global, require, _importDefaultUnused, _importAllUnused, module, exports, _dependencyMapUnused) {\n  module.exports = {\n  \"Book\": [\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01001001\",\n              \"Verse\": \"ఆదియందు దేవుడు భూమ్యాకాశములను సృజించెను.\"\n            },\n            {\n              \"Verseid\": \"01001002\",\n              \"Verse\": \"భూమి నిరాకారముగాను శూన్యముగాను ఉండెను; చీకటి అగాధజలము పైన కమ్మియుండెను.\"\n            },\n            {\n              \"Verseid\": \"01001003\",\n              \"Verse\": \"దేవుడు వెలుగు కమ్మని పలికెను; వెలుగు కలిగెను.\"\n            },\n            {\n              \"Verseid\": \"01001004\",\n              \"Verse\": \"వెలుగు మంచిదైనట్టు దేవుడు చూచెను; దేవుడు వెలుగును చీకటిని వేరుపరచెను.\"\n            },\n            {\n              \"Verseid\": \"01001005\",\n              \"Verse\": \"దేవుడు వెలుగునకు పగలనియు, చీకటికి రాత్రి అనియు పేరు పెట్టెను.\"\n            },\n            {\n              \"Verseid\": \"01001006\",\n              \"Verse\": \"మరియు దేవుడు జలముల మధ్య విశాలము కలిగి, జలములను జలములను వేరుచేయునదని పలికెను.\"\n            },\n            {\n              \"Verseid\": \"01001007\",\n              \"Verse\": \"దేవుడు ఆ విశాలమును చేసి, విశాలము క్రింది జలములను విశాలము పైనున్న జలములను వేరుపరచెను.\"\n            },\n            {\n              \"Verseid\": \"01001008\",\n              \"Verse\": \"దేవుడు ఆ విశాలమునకు ఆకాశమని పేరు పెట్టెను. అస్తమయమును ఉదయమును కలుగగా రెండవ దినము ఆయెను.\"\n            },\n            {\n              \"Verseid\": \"01001009\",\n              \"Verse\": \"దేవుడు ఆకాశముక్రింది జలములు ఒకచోటికి పోగై పొడినేల కనబడునుగాక అని పలికెను.\"\n            },\n            {\n              \"Verseid\": \"01001010\",\n              \"Verse\": \"దేవుడు పొడినేలకు భూమి అనియు, జలరాశికి సముద్రములనియు పేరు పెట్టెను.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01002001\",\n              \"Verse\": \"ఆ ప్రకారము భూమ్యాకాశములును, వాటి సర్వసమూహమును సంపూర్ణమాయెను.\"\n            },\n            {\n              \"Verseid\": \"01002002\",\n              \"Verse\": \"దేవుడు తాను చేసిన తన పనిని ఏడవ దినమందు సంపూర్ణ చేసెను.\"\n            },\n            {\n              \"Verseid\": \"01002003\",\n              \"Verse\": \"కాబట్టి దేవుడు ఏడవ దినమును ఆశీర్వదించి పరిశుద్ధపరచెను.\"\n            },\n            {\n              \"Verseid\": \"01002004\",\n              \"Verse\": \"భూమ్యాకాశములు సృజింపబడిన నాటి వృత్తాంతము ఇది.\"\n            },\n            {\n              \"Verseid\": \"01002005\",\n              \"Verse\": \"పొలములో మొక్కయు భూమిమీద గడ్డియు మొలవలేదు.\"\n            },\n            {\n              \"Verseid\": \"01002006\",\n              \"Verse\": \"అయితే భూమిలోనుండి మంచు లేచి నేలయంతటిమీద తడిపెను.\"\n            },\n            {\n              \"Verseid\": \"01002007\",\n              \"Verse\": \"దేవుడైన యెహోవా నేలమంటితో మనుష్యుని రూపించి వాని నాసికారంధ్రములలో జీవవాయువును ఊదెను.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01003001\",\n              \"Verse\": \"దేవుడైన యెహోవా చేసిన సమస్త భూజంతువులలో సర్పము మిక్కిలి యుక్తిగలది.\"\n            },\n            {\n              \"Verseid\": \"01003002\",\n              \"Verse\": \"అందుకు స్త్రీ ఆ సర్పముతో ఈ తోటలోని చెట్ల ఫలములను మేము తినవచ్చును.\"\n            },\n            {\n              \"Verseid\": \"01003003\",\n              \"Verse\": \"అయితే ఈ తోట మధ్యనున్న చెట్టు ఫలమునుగూర్చి మీరు చావకుండునట్లు దాని తినకూడదు.\"\n            },\n            {\n              \"Verseid\": \"01003004\",\n              \"Verse\": \"అందుకు సర్పము మీరు చావనే చావరు అని స్త్రీతో చెప్పెను.\"\n            },\n            {\n              \"Verseid\": \"01003005\",\n              \"Verse\": \"ఏలయనగా మీరు వాటిని తిను దినమున మీ కన్నులు తెరవబడునని దేవునికి తెలియును.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"02001001\",\n              \"Verse\": \"ఇశ్రాయేలు కుమారులలో ఐగుప్తునకు వచ్చినవారి నామములు ఇవి.\"\n            },\n            {\n              \"Verseid\": \"02001002\",\n              \"Verse\": \"రూబేను షిమ్యోను లేవి యూదా.\"\n            },\n            {\n              \"Verseid\": \"02001003\",\n              \"Verse\": \"ఇశ్శాఖారు జెబూలూను బెన్యామీను.\"\n            },\n            {\n              \"Verseid\": \"02001004\",\n              \"Verse\": \"దాను నఫ్తాలి గాదు ఆషేరు.\"\n            },\n            {\n              \"Verseid\": \"02001005\",\n              \"Verse\": \"యాకోబు గర్భమునుండి వచ్చిన వారందరు డెబ్బదిమంది.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"03001001\",\n              \"Verse\": \"యెహోవా మోషేను పిలిచి ప్రత్యక్షపు గుడారములోనుండి అతనితో ఇట్లనెను.\"\n            },\n            {\n              \"Verseid\": \"03001002\",\n              \"Verse\": \"ఇశ్రాయేలీయులతో ఇట్లు చెప్పుము.\"\n            },\n            {\n              \"Verseid\": \"03001003\",\n              \"Verse\": \"అతని అర్పణ పశువుల మందలోనిదైన దహనబలి అయినయెడల నిర్దోషమైన మగదాని అర్పింపవలెను.\"\n            },\n            {\n              \"Verseid\": \"03001004\",\n              \"Verse\": \"అతడు ఆ దహనబలి పశువు తలమీద చేయి ఉంచవలెను; అది అతనికొరకు ప్రాయశ్చిత్తముగా అంగీకరించబడును.\"\n            },\n            {\n              \"Verseid\": \"03001005\",\n              \"Verse\": \"అతడు యెహోవా సన్నిధిని ఆ కోడెదూడను వధింపవలెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"04001001\",\n              \"Verse\": \"ఇశ్రాయేలీయులు ఐగుప్తు దేశములోనుండి బయలుదేరిన రెండవ సంవత్సరము.\"\n            },\n            {\n              \"Verseid\": \"04001002\",\n              \"Verse\": \"ఇశ్రాయేలీయుల సమాజమంతటి లెక్క చూడుము.\"\n            },\n            {\n              \"Verseid\": \"04001003\",\n              \"Verse\": \"ఇరువది ఏండ్లు మొదలుకొని పైవారందరిని యుద్ధమునకు పోగలవారిని లెక్కించుము.\"\n            },\n            {\n              \"Verseid\": \"04001004\",\n              \"Verse\": \"ప్రతి గోత్రమునకు ఒక్కడు మీతో కూడ ఉండవలెను.\"\n            },\n            {\n              \"Verseid\": \"04001005\",\n              \"Verse\": \"మీతో కూడ నిలువవలసిన పురుషుల నామములు ఇవి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"05001001\",\n              \"Verse\": \"యొర్దానుకు ఈవలనున్న అరణ్యములో మోషే ఇశ్రాయేలీయులందరితో చెప్పిన మాటలు ఇవి.\"\n            },\n            {\n              \"Verseid\": \"05001002\",\n              \"Verse\": \"హోరేబునుండి శేయీరు కొండమార్గమునబడి కాదేషు బర్నేయవరకు పదునొకండు దినముల ప్రయాణము.\"\n            },\n            {\n              \"Verseid\": \"05001003\",\n              \"Verse\": \"నలువదియవ సంవత్సరము పదునొకండవ నెలలో జరిగెను.\"\n            },\n            {\n              \"Verseid\": \"05001004\",\n              \"Verse\": \"అతడు హెష్బోనులో నివసించిన అమోరీయుల రాజైన సీహోనును చంపిన తరువాత.\"\n            },\n            {\n              \"Verseid\": \"05001005\",\n              \"Verse\": \"యొర్దానుకు ఈవలనున్న మోయాబు దేశములో మోషే ఈ ధర్మశాస్త్రమును వివరింపసాగెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"06001001\",\n              \"Verse\": \"యెహోవా సేవకుడైన మోషే మృతినొందిన తరువాత జరిగినదేమనగా.\"\n            },\n            {\n              \"Verseid\": \"06001002\",\n              \"Verse\": \"నా సేవకుడైన మోషే మృతినొందెను గనుక నీవు లేచి ఈ యొర్దాను దాటుము.\"\n            },\n            {\n              \"Verseid\": \"06001003\",\n              \"Verse\": \"మీ అరికాలు త్రొక్కు ప్రతిచోటును నేను మీకిచ్చియున్నాను.\"\n            },\n            {\n              \"Verseid\": \"06001004\",\n              \"Verse\": \"నిబ్బరముగలిగి ధైర్యముగా ఉండుము.\"\n            },\n            {\n              \"Verseid\": \"06001005\",\n              \"Verse\": \"నేను నీకాజ్ఞాపించినది నిబ్బరముగలిగి ధైర్యముగా ఉండుము; భయపడకుము.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"07001001\",\n              \"Verse\": \"యెహోషువ మరణమైన తరువాత జరిగినదేమనగా.\"\n            },\n            {\n              \"Verseid\": \"07001002\",\n              \"Verse\": \"యూదా తన సహోదరుడైన షిమ్యోనుతో నాకు చీట్లవలన వచ్చిన భూమికి రమ్ము.\"\n            },\n            {\n              \"Verseid\": \"07001003\",\n              \"Verse\": \"యెహోవా యూదాకు తోడైయుండెను; అతడు కొండ దేశనివాసులను వెళ్లగొట్టెను.\"\n            },\n            {\n              \"Verseid\": \"07001004\",\n              \"Verse\": \"కిర్యత్సేఫెరును కొట్టి పట్టుకొనువానికి కాలేబు చెప్పెను.\"\n            },\n            {\n              \"Verseid\": \"07001005\",\n              \"Verse\": \"కనజు కుమారుడైన ఒత్నీయేలు దాని పట్టుకొనెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"08001001\",\n              \"Verse\": \"న్యాయాధిపతులు పాలించిన దినములలో దేశములో కరవు కలిగెను.\"\n            },\n            {\n              \"Verseid\": \"08001002\",\n              \"Verse\": \"బేత్లెహేము యూదాలో ఒకడు తన భార్యతో మోయాబు దేశమునకు వెళ్లెను.\"\n            },\n            {\n              \"Verseid\": \"08001003\",\n              \"Verse\": \"ఆ మనుష్యుని పేరు ఎలీమెలెకు; అతని భార్యపేరు నయోమి.\"\n            },\n            {\n              \"Verseid\": \"08001004\",\n              \"Verse\": \"వారు మోయాబు దేశమునకు వచ్చి అక్కడ నివసించిరి.\"\n            },\n            {\n              \"Verseid\": \"08001005\",\n              \"Verse\": \"మహ్లోను కిల్యోను అను ఇద్దరును మృతినొందిరి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"09001001\",\n              \"Verse\": \"రామాతయిం సోఫీములో ఒక మనుష్యుడుండెను.\"\n            },\n            {\n              \"Verseid\": \"09001002\",\n              \"Verse\": \"అతనికి ఇద్దరు భార్యలుండిరి; ఒకదాని పేరు హన్నా.\"\n            },\n            {\n              \"Verseid\": \"09001003\",\n              \"Verse\": \"ఈ మనుష్యుడు ఏటేట షిలోహులో సైన్యములకధిపతియగు యెహోవాను ఆరాధించుటకు వెళ్ళెను.\"\n            },\n            {\n              \"Verseid\": \"09001004\",\n              \"Verse\": \"దాని పోటికత్తెయు దానికి విసుగు కలుగజేయుచుండెను.\"\n            },\n            {\n              \"Verseid\": \"09001005\",\n              \"Verse\": \"అయితే హన్నాను ప్రేమించెను గనుక ఆమెకు ప్రశస్తమైన భాగమిచ్చెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"10001001\",\n              \"Verse\": \"సౌలు మరణమైన తరువాత జరిగినదేమనగా.\"\n            },\n            {\n              \"Verseid\": \"10001002\",\n              \"Verse\": \"దావీదు యెహోవాను విచారణ చేసి యూదా పట్టణములలో ఏదైనను నేను వెళ్ళవలెనా అని అడిగెను.\"\n            },\n            {\n              \"Verseid\": \"10001003\",\n              \"Verse\": \"యెహోవా వెళ్ళుమని చెప్పెను. దావీదు ఎక్కడికి వెళ్ళవలెనని అడిగెను.\"\n            },\n            {\n              \"Verseid\": \"10001004\",\n              \"Verse\": \"దావీదు అక్కడికి వెళ్ళెను; అతని ఇద్దరు భార్యలును వెళ్ళిరి.\"\n            },\n            {\n              \"Verseid\": \"10001005\",\n              \"Verse\": \"యూదా మనుష్యులు వచ్చి అక్కడ దావీదును యూదా వంశమునకు రాజుగా అభిషేకించిరి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"11001001\",\n              \"Verse\": \"దావీదు రాజు వయసు చాలిన ముసలివాడాయెను.\"\n            },\n            {\n              \"Verseid\": \"11001002\",\n              \"Verse\": \"అతని సేవకులు ప్రభువైన రాజుకొరకు యౌవనురాలైన కన్యకను వెదకవలెనని చెప్పిరి.\"\n            },\n            {\n              \"Verseid\": \"11001003\",\n              \"Verse\": \"ఇశ్రాయేలు దేశమంతట సుందరమైన కన్యకను వెదకిరి.\"\n            },\n            {\n              \"Verseid\": \"11001004\",\n              \"Verse\": \"ఆ కన్యక మిక్కిలి సౌందర్యము గలది; ఆమె రాజును ఆదరించెను.\"\n            },\n            {\n              \"Verseid\": \"11001005\",\n              \"Verse\": \"హగ్గీతు కుమారుడైన అదోనీయా నేను రాజునగుదునని చెప్పుకొని తన్ను తాను హెచ్చించుకొనెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"12001001\",\n              \"Verse\": \"అహాబు మరణమైన తరువాత మోయాబు ఇశ్రాయేలుమీద తిరుగుబాటు చేసెను.\"\n            },\n            {\n              \"Verseid\": \"12001002\",\n              \"Verse\": \"అహజ్యా తన మేడగదిలోని ఊచలగుండ క్రిందపడెను.\"\n            },\n            {\n              \"Verseid\": \"12001003\",\n              \"Verse\": \"అతడు ఎక్రోను దేవుడైన బయల్జెబూబును విచారణచేయుడని దూతలను పంపెను.\"\n            },\n            {\n              \"Verseid\": \"12001004\",\n              \"Verse\": \"అయితే యెహోవా దూత తిష్బీయుడైన ఏలీయాతో ఆ దూతలను ఎదుర్కొనుటకు లెమ్మనెను.\"\n            },\n            {\n              \"Verseid\": \"12001005\",\n              \"Verse\": \"ఏలీయా నేను దేవుని మనుష్యుడనైతే ఆకాశమునుండి అగ్ని దిగునుగాక అని చెప్పెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"13001001\",\n              \"Verse\": \"ఆదాము షేతు ఎనోషు.\"\n            },\n            {\n              \"Verseid\": \"13001002\",\n              \"Verse\": \"కేయినాను మహలలేలు యెరెదు.\"\n            },\n            {\n              \"Verseid\": \"13001003\",\n              \"Verse\": \"హనోకు మెతూషెల లెమెకు.\"\n            },\n            {\n              \"Verseid\": \"13001004\",\n              \"Verse\": \"నోవహు షేము హాము యాపెతు.\"\n            },\n            {\n              \"Verseid\": \"13001005\",\n              \"Verse\": \"యాపెతు కుమారులు గోమెరు మాగోగు మాదయి యావాను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"14001001\",\n              \"Verse\": \"దావీదు కుమారుడైన సొలొమోను తన రాజ్యమందు బలపరచబడెను.\"\n            },\n            {\n              \"Verseid\": \"14001002\",\n              \"Verse\": \"సొలొమోను ఇశ్రాయేలీయులందరితో సహస్రాధిపతులతో మాటలాడెను.\"\n            },\n            {\n              \"Verseid\": \"14001003\",\n              \"Verse\": \"సొలొమోనును అతనితో ఉన్న సమాజమంతయు ఉన్నతస్థలమునకు వెళ్ళిరి.\"\n            },\n            {\n              \"Verseid\": \"14001004\",\n              \"Verse\": \"ఆ రాత్రియందు దేవుడు సొలొమోనునకు కనబడెను.\"\n            },\n            {\n              \"Verseid\": \"14001005\",\n              \"Verse\": \"సొలొమోను దేవునితో నా తండ్రియైన దావీదునకు నీవు గొప్ప కృప చూపించితివి అని చెప్పెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"15001001\",\n              \"Verse\": \"పారసీకదేశపు రాజైన కోరెషు మొదటి సంవత్సరమందు.\"\n            },\n            {\n              \"Verseid\": \"15001002\",\n              \"Verse\": \"యెహోవా పారసీకదేశపు రాజైన కోరెషు ఆత్మను ప్రేరేపించెను.\"\n            },\n            {\n              \"Verseid\": \"15001003\",\n              \"Verse\": \"పారసీకదేశపు రాజైన కోరెషు ఆకాశదేవుడైన యెహోవా లోకమందలి రాజ్యములన్నిటిని నాకిచ్చెను.\"\n            },\n            {\n              \"Verseid\": \"15001004\",\n              \"Verse\": \"ఆయన జనులలో మీయందు ఎవరున్నారు? వాని దేవుడు వానికి తోడైయుండును గాక.\"\n            },\n            {\n              \"Verseid\": \"15001005\",\n              \"Verse\": \"అప్పుడు యూదా బెన్యామీనుల పితరుల ప్రధానులు లేచిరి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"16001001\",\n              \"Verse\": \"హకల్యా కుమారుడైన నెహెమ్యా మాటలు.\"\n            },\n            {\n              \"Verseid\": \"16001002\",\n              \"Verse\": \"ఈ మాటలు విని నేను కూర్చుండి యేడ్చితిని.\"\n            },\n            {\n              \"Verseid\": \"16001003\",\n              \"Verse\": \"ఆకాశదేవుడైన యెహోవా నేను నిన్ను వేడుకొనుచున్నాను.\"\n            },\n            {\n              \"Verseid\": \"16001004\",\n              \"Verse\": \"నిబంధనను కృపను కాపాడు మహా భయంకరుడవైన దేవా.\"\n            },\n            {\n              \"Verseid\": \"16001005\",\n              \"Verse\": \"నీ సేవకుని ప్రార్థన వినుటకు నీ చెవి ఆలకించి నీ కన్నులు తెరచుము.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"17001001\",\n              \"Verse\": \"అహష్వేరోషు దినములలో జరిగినదేమనగా.\"\n            },\n            {\n              \"Verseid\": \"17001002\",\n              \"Verse\": \"ఆ దినములలో అహష్వేరోషు రాజు సింహాసనమునకూర్చుండెను.\"\n            },\n            {\n              \"Verseid\": \"17001003\",\n              \"Verse\": \"అతని యేలుబడియందు మూడవ సంవత్సరమున అతని సమస్త అధిపతులకు విందుచేసెను.\"\n            },\n            {\n              \"Verseid\": \"17001004\",\n              \"Verse\": \"రాణియైన వష్తియు స్త్రీలకు విందు చేసెను.\"\n            },\n            {\n              \"Verseid\": \"17001005\",\n              \"Verse\": \"ఏడవ దినమున రాజు హృదయము ద్రాక్షారసముచేత ఆనందమాయెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"18001001\",\n              \"Verse\": \"ఊజు దేశమందు యోబు అను ఒక మనుష్యుడుండెను.\"\n            },\n            {\n              \"Verseid\": \"18001002\",\n              \"Verse\": \"ఆ మనుష్యుడు యథార్థవంతుడును న్యాయస్థుడును దేవునియందు భయభక్తులు గలవాడును.\"\n            },\n            {\n              \"Verseid\": \"18001003\",\n              \"Verse\": \"అతని ఆస్తి ఏడువేల గొఱ్ఱెలు మూడువేల ఒంటెలు.\"\n            },\n            {\n              \"Verseid\": \"18001004\",\n              \"Verse\": \"అతని కుమారులు వారివారి ఇండ్లలో విందుచేయుచుండిరి.\"\n            },\n            {\n              \"Verseid\": \"18001005\",\n              \"Verse\": \"యోబు వారిని పిలిపించి పవిత్రపరచి ఉదయమునే లేచెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19001001\",\n              \"Verse\": \"భక్తిహీనుల ఆలోచన చొప్పున నడువక పాపుల మార్గమున నిలువక వాడు ధన్యుడు.\"\n            },\n            {\n              \"Verseid\": \"19001002\",\n              \"Verse\": \"యెహోవా ధర్మశాస్త్రమునందు అతడు ఆనందించును. దివారాత్రము దానిని ధ్యానించును.\"\n            },\n            {\n              \"Verseid\": \"19001003\",\n              \"Verse\": \"అతడు నీటి కాలువల ప్రక్కన నాటబడి ఆకు వాడక తన కాలమందు ఫలమిచ్చు చెట్టువలె నుండును.\"\n            },\n            {\n              \"Verseid\": \"19001004\",\n              \"Verse\": \"భక్తిహీనులు అట్లుండరు, గాలికి ఎగురగొట్టబడు పొట్టువలె నుందురు.\"\n            },\n            {\n              \"Verseid\": \"19001005\",\n              \"Verse\": \"కాబట్టి న్యాయవిమర్శలో భక్తిహీనులును నీతిమంతుల సభలో పాపులును నిలువలేరు.\"\n            },\n            {\n              \"Verseid\": \"19001006\",\n              \"Verse\": \"నీతిమంతుల మార్గమును యెహోవా జ్ఞాపకముంచును భక్తిహీనుల మార్గము నాశనమగును.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19002001\",\n              \"Verse\": \"యెహోవా నా కాపరి; నాకు లేమి కలుగదు.\"\n            },\n            {\n              \"Verseid\": \"19002002\",\n              \"Verse\": \"పచ్చిక బయళ్లలో ఆయన నన్ను పరుండజేయును. సేదదీర్చు జలములయొద్దకు నన్ను నడిపించును.\"\n            },\n            {\n              \"Verseid\": \"19002003\",\n              \"Verse\": \"ఆయన నా ప్రాణమును తెప్పరిల్లజేయును. తన నామమునుబట్టి నీతిమార్గములలో నన్ను నడిపించును.\"\n            },\n            {\n              \"Verseid\": \"19002004\",\n              \"Verse\": \"గాఢాంధకారపు లోయలో నేను సంచరించినను ఏ అపాయమునకు భయపడను.\"\n            },\n            {\n              \"Verseid\": \"19002005\",\n              \"Verse\": \"నా శత్రువులయెదుట నీవు నాకు భోజనము సిద్ధపరచుదువు.\"\n            },\n            {\n              \"Verseid\": \"19002006\",\n              \"Verse\": \"నా జీవితకాలమంతయు నన్ను శుభమును కృపయును వెంబడించును.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19003001\",\n              \"Verse\": \"యెహోవా నా వెలుగును నా రక్షణయునైయున్నాడు; నేనెవరికి భయపడుదును?\"\n            },\n            {\n              \"Verseid\": \"19003002\",\n              \"Verse\": \"నా శరీరమును తినుటకు దుష్టులు నామీదికి వచ్చినప్పుడు వారు తొట్రిల్లి పడిరి.\"\n            },\n            {\n              \"Verseid\": \"19003003\",\n              \"Verse\": \"సేన నామీద దిగినను నా హృదయము భయపడదు.\"\n            },\n            {\n              \"Verseid\": \"19003004\",\n              \"Verse\": \"ఒక్కటి నేను యెహోవాను అడిగియున్నాను దానినే నేను వెదకుచున్నాను.\"\n            },\n            {\n              \"Verseid\": \"19003005\",\n              \"Verse\": \"ఆపద కాలమందు ఆయన తన పర్ణశాలలో నన్ను దాచును.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"20001001\",\n              \"Verse\": \"ఇశ్రాయేలు రాజగు దావీదు కుమారుడైన సొలొమోను సామెతలు.\"\n            },\n            {\n              \"Verseid\": \"20001002\",\n              \"Verse\": \"జ్ఞానమును ఉపదేశమును తెలిసికొనుటకును.\"\n            },\n            {\n              \"Verseid\": \"20001003\",\n              \"Verse\": \"జ్ఞానముయొక్క బోధను నీతిన్యాయసమతలను చేపట్టుటకును.\"\n            },\n            {\n              \"Verseid\": \"20001004\",\n              \"Verse\": \"జ్ఞానహీనులకు బుద్ధినియ్యుటకును యవనస్థులకు తెలివిని వివేచనను ఇయ్యుటకును.\"\n            },\n            {\n              \"Verseid\": \"20001005\",\n              \"Verse\": \"యెహోవాయందు భయభక్తులు కలిగియుండుటయే జ్ఞానమునకు ఆరంభము.\"\n            },\n            {\n              \"Verseid\": \"20001006\",\n              \"Verse\": \"నా కుమారుడా, నీ తండ్రి ఉపదేశమును ఆలకింపుము నీ తల్లి చెప్పు బోధను త్రోసివేయకుము.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"21001001\",\n              \"Verse\": \"యెరూషలేములో రాజైన దావీదు కుమారుడగు ప్రసంగి మాటలు.\"\n            },\n            {\n              \"Verseid\": \"21001002\",\n              \"Verse\": \"వ్యర్థమని ప్రసంగి చెప్పుచున్నాడు, వ్యర్థము; సమస్తము వ్యర్థమే.\"\n            },\n            {\n              \"Verseid\": \"21001003\",\n              \"Verse\": \"సూర్యుని క్రింద నరుడు పడు కష్టమంతటిచేత వానికి లాభమేమి?\"\n            },\n            {\n              \"Verseid\": \"21001004\",\n              \"Verse\": \"ఒక తరము గతించిపోవును మరి ఒక తరము వచ్చును.\"\n            },\n            {\n              \"Verseid\": \"21001005\",\n              \"Verse\": \"సూర్యుడు ఉదయించును సూర్యుడు అస్తమించును.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"22001001\",\n              \"Verse\": \"సొలొమోను రచించిన పరమగీతము.\"\n            },\n            {\n              \"Verseid\": \"22001002\",\n              \"Verse\": \"అతడు తన నోటి ముద్దులతో నన్ను ముద్దుపెట్టుకొనును గాక.\"\n            },\n            {\n              \"Verseid\": \"22001003\",\n              \"Verse\": \"నన్ను ఆకర్షించుము మేము నీ వెంట పరుగెత్తుదుము.\"\n            },\n            {\n              \"Verseid\": \"22001004\",\n              \"Verse\": \"యెరూషలేము కుమార్తెలారా, నేను నల్లనిదానను గాని అందమైనదానను.\"\n            },\n            {\n              \"Verseid\": \"22001005\",\n              \"Verse\": \"నేను నల్లనిదానను గనుక నన్ను చూడకుడి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"23001001\",\n              \"Verse\": \"ఆమోజు కుమారుడైన యెషయాకు యూదా యెరూషలేములనుగూర్చి కలిగిన దర్శనము.\"\n            },\n            {\n              \"Verseid\": \"23001002\",\n              \"Verse\": \"ఆకాశమా, ఆలకించుము; భూమీ, చెవియొగ్గుము; యెహోవా మాటలాడుచున్నాడు.\"\n            },\n            {\n              \"Verseid\": \"23001003\",\n              \"Verse\": \"నేను పిల్లలను పెంచి పెద్దచేసితిని వారు నామీద తిరుగుబాటు చేసిరి.\"\n            },\n            {\n              \"Verseid\": \"23001004\",\n              \"Verse\": \"ఎద్దు తన యజమానుని ఎరుగును, గాడిద తన యజమాని తొట్టిని ఎరుగును.\"\n            },\n            {\n              \"Verseid\": \"23001005\",\n              \"Verse\": \"అయ్యో, పాపముచేయు జనమా, దోషభరితమైన ప్రజలారా.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"24001001\",\n              \"Verse\": \"హిల్కీయా కుమారుడైన యిర్మీయా మాటలు.\"\n            },\n            {\n              \"Verseid\": \"24001002\",\n              \"Verse\": \"యెహోవా వాక్కు నాకు ప్రత్యక్షమై ఇట్లనెను.\"\n            },\n            {\n              \"Verseid\": \"24001003\",\n              \"Verse\": \"గర్భమందు నిన్ను రూపించక మునుపే నేను నిన్నెరిగితిని.\"\n            },\n            {\n              \"Verseid\": \"24001004\",\n              \"Verse\": \"అందుకు నేను అయ్యో ప్రభువా, నేను బాలుడను నాకు మాటలాడ చేతకాదు అంటిని.\"\n            },\n            {\n              \"Verseid\": \"24001005\",\n              \"Verse\": \"అయితే యెహోవా నేను బాలుడనని చెప్పకుమని నాతో అనెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"25001001\",\n              \"Verse\": \"జనులతో నిండియుండిన ఈ పట్టణము ఏకాంతముగా ఎట్లు కూర్చుండెను!\"\n            },\n            {\n              \"Verseid\": \"25001002\",\n              \"Verse\": \"రాత్రివేళ ఆమె బహుగా ఏడ్చుచున్నది; ఆమె కన్నీళ్లు చెంపలమీద నున్నవి.\"\n            },\n            {\n              \"Verseid\": \"25001003\",\n              \"Verse\": \"బాధవలనను దాస్యమువలనను యూదా చెరగా పోయెను.\"\n            },\n            {\n              \"Verseid\": \"25001004\",\n              \"Verse\": \"సియోను మార్గములు దుఃఖించుచున్నవి; పండుగలకు ఎవరును రారు.\"\n            },\n            {\n              \"Verseid\": \"25001005\",\n              \"Verse\": \"దాని శత్రువులు ప్రధానులైరి; దాని విరోధులు వర్ధిల్లుచున్నారు.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"26001001\",\n              \"Verse\": \"ముప్పదియవ సంవత్సరమందు జరిగినదేమనగా.\"\n            },\n            {\n              \"Verseid\": \"26001002\",\n              \"Verse\": \"ఆకాశము తెరవబడగా దేవుని దర్శనములు నాకు కలిగెను.\"\n            },\n            {\n              \"Verseid\": \"26001003\",\n              \"Verse\": \"యెహోవా వాక్కు యాజకుడైన యెహెజ్కేలునకు ప్రత్యక్షమాయెను.\"\n            },\n            {\n              \"Verseid\": \"26001004\",\n              \"Verse\": \"నేను చూడగా ఉత్తర దిక్కునుండి బహు వేగముగల ఒక పెనుగాలి వచ్చుచుండెను.\"\n            },\n            {\n              \"Verseid\": \"26001005\",\n              \"Verse\": \"దాని మధ్యనుండి నాలుగు జీవుల రూపము కనబడెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"27001001\",\n              \"Verse\": \"యూదా రాజైన యెహోయాకీము ఏలుబడిలో మూడవ సంవత్సరమున.\"\n            },\n            {\n              \"Verseid\": \"27001002\",\n              \"Verse\": \"ప్రభువు యూదా రాజైన యెహోయాకీమును అతని చేతికి అప్పగించెను.\"\n            },\n            {\n              \"Verseid\": \"27001003\",\n              \"Verse\": \"రాజు తన నపుంసకుల అధిపతియైన అష్పనజుతో చెప్పెను.\"\n            },\n            {\n              \"Verseid\": \"27001004\",\n              \"Verse\": \"ఏ దోషమును లేని సౌందర్యవంతులైన యవనస్థులను.\"\n            },\n            {\n              \"Verseid\": \"27001005\",\n              \"Verse\": \"దానియేలు తన్నుతాను అపవిత్రపరచుకొనకూడదని తన హృదయమందు నిశ్చయించుకొనెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"28001001\",\n              \"Verse\": \"హోషేయకు ప్రత్యక్షమైన యెహోవా వాక్కు.\"\n            },\n            {\n              \"Verseid\": \"28001002\",\n              \"Verse\": \"నీవు వెళ్లి ఒక భార్యను తెచ్చుకొనుము.\"\n            },\n            {\n              \"Verseid\": \"28001003\",\n              \"Verse\": \"అతడు వెళ్ళి దిబ్లయీము కుమార్తెయైన గోమెరును తెచ్చుకొనెను.\"\n            },\n            {\n              \"Verseid\": \"28001004\",\n              \"Verse\": \"యెహోవా అతనితో వానికి యెజ్రెయేలు అని పేరు పెట్టుమనెను.\"\n            },\n            {\n              \"Verseid\": \"28001005\",\n              \"Verse\": \"ఇశ్రాయేలీయుల సంఖ్య సముద్రపు ఇసుకవలె ఉండును.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"29001001\",\n              \"Verse\": \"పెతూయేలు కుమారుడైన యోవేలునకు ప్రత్యక్షమైన యెహోవా వాక్కు.\"\n            },\n            {\n              \"Verseid\": \"29001002\",\n              \"Verse\": \"పెద్దలారా, ఈ మాట ఆలకించుడి; దేశనివాసులారా, చెవియొగ్గుడి.\"\n            },\n            {\n              \"Verseid\": \"29001003\",\n              \"Verse\": \"గొంగళి పురుగు తిన్నది తక్షిణ మిడతలు తినెను.\"\n            },\n            {\n              \"Verseid\": \"29001004\",\n              \"Verse\": \"త్రాగుబోతులారా, మేల్కొని యేడ్వుడి.\"\n            },\n            {\n              \"Verseid\": \"29001005\",\n              \"Verse\": \"బలమైన జనము నా దేశముమీదికి వచ్చెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"30001001\",\n              \"Verse\": \"తెకోవ గొఱ్ఱెల కాపరులలో ఒకడైన ఆమోసు మాటలు.\"\n            },\n            {\n              \"Verseid\": \"30001002\",\n              \"Verse\": \"యెహోవా సియోనులో నుండి గర్జించును అని అతడు చెప్పెను.\"\n            },\n            {\n              \"Verseid\": \"30001003\",\n              \"Verse\": \"దమస్కు చేసిన మూడు అతిక్రమములనుబట్టియు నాలుగు అతిక్రమములనుబట్టియు.\"\n            },\n            {\n              \"Verseid\": \"30001004\",\n              \"Verse\": \"యెహోవా ఇట్లనుచున్నాడు గాజా చేసిన మూడు అతిక్రమములనుబట్టి.\"\n            },\n            {\n              \"Verseid\": \"30001005\",\n              \"Verse\": \"నేను గాజా ప్రాకారములమీద అగ్ని పంపెదను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"31001001\",\n              \"Verse\": \"ఓబద్యాకు కలిగిన దర్శనము. ఎదోమునుగూర్చి ప్రభువైన యెహోవా సెలవిచ్చునదేమనగా.\"\n            },\n            {\n              \"Verseid\": \"31001002\",\n              \"Verse\": \"జనముల మధ్య నిన్ను అల్పునిగా చేసియున్నాను.\"\n            },\n            {\n              \"Verseid\": \"31001003\",\n              \"Verse\": \"నీ హృదయ గర్వము నిన్ను మోసపుచ్చెను.\"\n            },\n            {\n              \"Verseid\": \"31001004\",\n              \"Verse\": \"నీవు పక్షిరాజువలె ఎంత ఎత్తుగా ఎగిరినను.\"\n            },\n            {\n              \"Verseid\": \"31001005\",\n              \"Verse\": \"ఆ దినమందు ఎదోములోనుండి జ్ఞానులను నేను నశింపజేయుదును.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"32001001\",\n              \"Verse\": \"అమిత్తయి కుమారుడైన యోనాకు యెహోవా వాక్కు ప్రత్యక్షమై.\"\n            },\n            {\n              \"Verseid\": \"32001002\",\n              \"Verse\": \"నీవు లేచి ఆ మహా పట్టణమైన నీనెవెకు వెళ్ళుము.\"\n            },\n            {\n              \"Verseid\": \"32001003\",\n              \"Verse\": \"అయితే యోనా తర్షీషునకు పారిపోవుటకు లేచెను.\"\n            },\n            {\n              \"Verseid\": \"32001004\",\n              \"Verse\": \"అయితే యెహోవా సముద్రముమీద బహు వేగముగల గాలిని పంపెను.\"\n            },\n            {\n              \"Verseid\": \"32001005\",\n              \"Verse\": \"నావికులు భయపడి ఎవరి దేవునికి వారు మొఱ్ఱపెట్టిరి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"33001001\",\n              \"Verse\": \"మీకాకు ప్రత్యక్షమైన యెహోవా వాక్కు.\"\n            },\n            {\n              \"Verseid\": \"33001002\",\n              \"Verse\": \"జనులారా, మీరందరు ఆలకించుడి; భూమీ, చెవియొగ్గుము.\"\n            },\n            {\n              \"Verseid\": \"33001003\",\n              \"Verse\": \"యెహోవా తన స్థలమునుండి బయలుదేరి వచ్చుచున్నాడు.\"\n            },\n            {\n              \"Verseid\": \"33001004\",\n              \"Verse\": \"ఆయన క్రింద పర్వతములు కరిగిపోవును.\"\n            },\n            {\n              \"Verseid\": \"33001005\",\n              \"Verse\": \"ఇదంతయు యాకోబు అతిక్రమము నిమిత్తమే.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"34001001\",\n              \"Verse\": \"నీనెవెను గూర్చిన దేవోక్తి. ఎల్కోషీయుడైన నహూము దర్శన గ్రంథము.\"\n            },\n            {\n              \"Verseid\": \"34001002\",\n              \"Verse\": \"దేవుడు రోషముగలవాడు; యెహోవా ప్రతిదండన చేయువాడు.\"\n            },\n            {\n              \"Verseid\": \"34001003\",\n              \"Verse\": \"యెహోవా దీర్ఘశాంతుడు మహాబలము గలవాడు.\"\n            },\n            {\n              \"Verseid\": \"34001004\",\n              \"Verse\": \"ఆయన సముద్రమును గద్దించి దాని ఎండిపోజేయును.\"\n            },\n            {\n              \"Verseid\": \"34001005\",\n              \"Verse\": \"పర్వతములు ఆయన యెదుట కంపించును; కొండలు కరిగిపోవును.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"35001001\",\n              \"Verse\": \"ప్రవక్తయైన హబక్కూకునకు ప్రత్యక్షమైన దేవోక్తి.\"\n            },\n            {\n              \"Verseid\": \"35001002\",\n              \"Verse\": \"యెహోవా, నేనెంతకాలము మొఱ్ఱపెట్టుచుండగా నీవు ఆలకింపకుందువు?\"\n            },\n            {\n              \"Verseid\": \"35001003\",\n              \"Verse\": \"నీవు నాకు దోషమును ఎందుకు చూపించుచున్నావు?\"\n            },\n            {\n              \"Verseid\": \"35001004\",\n              \"Verse\": \"కాబట్టి ధర్మశాస్త్రము నిర్బలమైనది; న్యాయము జరుగుటలేదు.\"\n            },\n            {\n              \"Verseid\": \"35001005\",\n              \"Verse\": \"జనములలో చూడుడి, ఆలోచించుడి, ఆశ్చర్యపడుడి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"36001001\",\n              \"Verse\": \"జెఫన్యాకు ప్రత్యక్షమైన యెహోవా వాక్కు.\"\n            },\n            {\n              \"Verseid\": \"36001002\",\n              \"Verse\": \"భూమిమీదనున్న సమస్తమును నేను బొత్తిగా నశింపజేసెదను.\"\n            },\n            {\n              \"Verseid\": \"36001003\",\n              \"Verse\": \"మనుష్యులను జంతువులను నేను నశింపజేసెదను.\"\n            },\n            {\n              \"Verseid\": \"36001004\",\n              \"Verse\": \"యూదామీద నా చేయి చాపెదను.\"\n            },\n            {\n              \"Verseid\": \"36001005\",\n              \"Verse\": \"మేడలమీద ఆకాశ సైన్యమును పూజించువారిని నశింపజేసెదను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"37001001\",\n              \"Verse\": \"దర్యావేషు రాజు రెండవ సంవత్సరమందు.\"\n            },\n            {\n              \"Verseid\": \"37001002\",\n              \"Verse\": \"సైన్యములకధిపతియగు యెహోవా ఈలాగు సెలవిచ్చుచున్నాడు.\"\n            },\n            {\n              \"Verseid\": \"37001003\",\n              \"Verse\": \"ఇది మీరు పైకప్పుగల ఇండ్లలో నివసించు కాలమా?\"\n            },\n            {\n              \"Verseid\": \"37001004\",\n              \"Verse\": \"మీరు విస్తారముగా విత్తితిరి గాని కొంచెముగా తెచ్చుకొంటిరి.\"\n            },\n            {\n              \"Verseid\": \"37001005\",\n              \"Verse\": \"సైన్యములకధిపతియగు యెహోవా మీ ప్రవర్తన విషయమై ఆలోచించుకొనుడని సెలవిచ్చుచున్నాడు.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"38001001\",\n              \"Verse\": \"దర్యావేషు రెండవ సంవత్సరము ఎనిమిదవ నెలలో.\"\n            },\n            {\n              \"Verseid\": \"38001002\",\n              \"Verse\": \"యెహోవా మీ పితరులమీద బహుగా కోపగించెను.\"\n            },\n            {\n              \"Verseid\": \"38001003\",\n              \"Verse\": \"కాబట్టి సైన్యములకధిపతియగు యెహోవా ఈలాగు సెలవిచ్చుచున్నాడని వారితో చెప్పుము.\"\n            },\n            {\n              \"Verseid\": \"38001004\",\n              \"Verse\": \"నాయొద్దకు తిరుగుడి అని సైన్యములకధిపతియగు యెహోవా సెలవిచ్చుచున్నాడు.\"\n            },\n            {\n              \"Verseid\": \"38001005\",\n              \"Verse\": \"మీ పితరులవలె ఉండకుడి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"39001001\",\n              \"Verse\": \"మలాకీ ద్వారా ఇశ్రాయేలునకు ప్రత్యక్షమైన యెహోవా వాక్కు.\"\n            },\n            {\n              \"Verseid\": \"39001002\",\n              \"Verse\": \"నేను మిమ్మును ప్రేమించితినని యెహోవా సెలవిచ్చుచున్నాడు.\"\n            },\n            {\n              \"Verseid\": \"39001003\",\n              \"Verse\": \"ఏశావు యాకోబు సహోదరుడు గదా అని యెహోవా సెలవిచ్చుచున్నాడు.\"\n            },\n            {\n              \"Verseid\": \"39001004\",\n              \"Verse\": \"అయినను యాకోబును ప్రేమించితిని ఏశావును ద్వేషించితిని.\"\n            },\n            {\n              \"Verseid\": \"39001005\",\n              \"Verse\": \"అతని పర్వతములను పాడుచేసి అతని స్వాస్థ్యమును అరణ్యపు నక్కలకు అప్పగించితిని.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"40001001\",\n              \"Verse\": \"అబ్రాహాము కుమారుడైన దావీదు కుమారుడగు యేసుక్రీస్తు వంశావళి.\"\n            },\n            {\n              \"Verseid\": \"40001002\",\n              \"Verse\": \"అబ్రాహాము ఇస్సాకును కనెను; ఇస్సాకు యాకోబును కనెను; యాకోబు యూదాను అతని సహోదరులను కనెను.\"\n            },\n            {\n              \"Verseid\": \"40001003\",\n              \"Verse\": \"యూదా తామారువలన పెరెసును జెరహును కనెను.\"\n            },\n            {\n              \"Verseid\": \"40001004\",\n              \"Verse\": \"అరాము అమ్మీనాదాబును కనెను; అమ్మీనాదాబు నయస్సోనును కనెను.\"\n            },\n            {\n              \"Verseid\": \"40001005\",\n              \"Verse\": \"సల్మోను రాహాబువలన బోయజును కనెను; బోయజు రూతువలన ఓబేదును కనెను.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"40002001\",\n              \"Verse\": \"హేరోదురాజు దినములలో యూదయ బేత్లెహేములో యేసు పుట్టిన తరువాత.\"\n            },\n            {\n              \"Verseid\": \"40002002\",\n              \"Verse\": \"యూదులకు రాజుగా పుట్టినవాడు ఎక్కడ ఉన్నాడు?\"\n            },\n            {\n              \"Verseid\": \"40002003\",\n              \"Verse\": \"హేరోదురాజు ఈ సంగతి విని కలవరపడెను.\"\n            },\n            {\n              \"Verseid\": \"40002004\",\n              \"Verse\": \"అతడు ప్రజలయొక్క ప్రధానయాజకులను శాస్త్రులను అందరిని సమకూర్చెను.\"\n            },\n            {\n              \"Verseid\": \"40002005\",\n              \"Verse\": \"యూదాదేశపు బేత్లెహేమా, యూదా ప్రధానులలో నీవు ఎంతమాత్రమును అల్పమైనది కావు.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"41001001\",\n              \"Verse\": \"దేవుని కుమారుడైన యేసుక్రీస్తు సువార్త ప్రారంభము.\"\n            },\n            {\n              \"Verseid\": \"41001002\",\n              \"Verse\": \"ప్రవక్తల గ్రంథములలో వ్రాయబడినట్టు ఇదిగో నీకు ముందుగా నా దూతను పంపుచున్నాను.\"\n            },\n            {\n              \"Verseid\": \"41001003\",\n              \"Verse\": \"అరణ్యములో కేకవేయువాని స్వరము ప్రభువు మార్గమును సిద్ధపరచుడి.\"\n            },\n            {\n              \"Verseid\": \"41001004\",\n              \"Verse\": \"యోహాను అరణ్యములో బాప్తిస్మమిచ్చుచు మారుమనస్సు బాప్తిస్మమును ప్రకటించెను.\"\n            },\n            {\n              \"Verseid\": \"41001005\",\n              \"Verse\": \"యూదయ దేశస్థులందరును యెరూషలేము వారందరును అతని యొద్దకు వెళ్ళిరి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"42001001\",\n              \"Verse\": \"మనలో నెరవేరిన సంగతులనుగూర్చి వివరణ వ్రాయుటకు అనేకులు ప్రయత్నించిరి.\"\n            },\n            {\n              \"Verseid\": \"42001002\",\n              \"Verse\": \"నేను కూడా మొదటినుండి అన్ని సంగతులను జాగ్రత్తగా పరిశీలించి.\"\n            },\n            {\n              \"Verseid\": \"42001003\",\n              \"Verse\": \"యూదయ రాజైన హేరోదు దినములలో జెకర్యా అను ఒక యాజకుడుండెను.\"\n            },\n            {\n              \"Verseid\": \"42001004\",\n              \"Verse\": \"వారిద్దరును దేవుని యెదుట నీతిమంతులై యుండిరి.\"\n            },\n            {\n              \"Verseid\": \"42001005\",\n              \"Verse\": \"ఎలీసబెతు గొడ్రాలగుటచేత వారికి సంతానము లేకుండెను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"43001001\",\n              \"Verse\": \"ఆదియందు వాక్యముండెను, ఆ వాక్యము దేవుని యొద్ద ఉండెను, ఆ వాక్యము దేవుడై యుండెను.\"\n            },\n            {\n              \"Verseid\": \"43001002\",\n              \"Verse\": \"ఆయన ఆదియందు దేవునియొద్ద ఉండెను.\"\n            },\n            {\n              \"Verseid\": \"43001003\",\n              \"Verse\": \"సమస్తమును ఆయన మూలముగా కలిగెను; కలిగియున్నదేదియు ఆయన లేకుండ కలుగలేదు.\"\n            },\n            {\n              \"Verseid\": \"43001004\",\n              \"Verse\": \"ఆయనలో జీవముండెను; ఆ జీవము మనుష్యులకు వెలుగైయుండెను.\"\n            },\n            {\n              \"Verseid\": \"43001005\",\n