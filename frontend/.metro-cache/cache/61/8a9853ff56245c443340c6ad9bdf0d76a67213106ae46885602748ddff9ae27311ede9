    ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"61001001\",\n              \"Verse\": \"యేసుక్రీస్తు దాసుడును అపొస్తలుడునైన సీమోను పేతురు.\"\n            },\n            {\n              \"Verseid\": \"61001002\",\n              \"Verse\": \"కృపయు సమాధానమును మీకు విస్తరించును గాక.\"\n            },\n            {\n              \"Verseid\": \"61001003\",\n              \"Verse\": \"ఆయన దివ్యశక్తి జీవమునకును భక్తికిని కావలసినవన్నియు మనకు దయచేసెను.\"\n            },\n            {\n              \"Verseid\": \"61001004\",\n              \"Verse\": \"దీనివలన ఆయన మనకు అమూల్యమైనవియు అతి గొప్పవియునైన వాగ్దానములను అనుగ్రహించెను.\"\n            },\n            {\n              \"Verseid\": \"61001005\",\n              \"Verse\": \"ఈ హేతువునుబట్టి మీరు పూర్ణ జాగ్రత్తతో మీ విశ్వాసమునకు సద్గుణమును చేర్చుడి.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"62001001\",\n              \"Verse\": \"ఆదినుండి ఉన్నదియు మేము విన్నదియు.\"\n            },\n            {\n              \"Verseid\": \"62001002\",\n              \"Verse\": \"మేము చూచినదానిని విన్నదానిని మీకు తెలియజేయుచున్నాము.\"\n            },\n            {\n              \"Verseid\": \"62001003\",\n              \"Verse\": \"మీ సంతోషము పరిపూర్ణమగునట్లు ఈ సంగతులను మీకు వ్రాయుచున్నాము.\"\n            },\n            {\n              \"Verseid\": \"62001004\",\n              \"Verse\": \"ఆయనయొద్దనుండి మేము విని మీకు ప్రకటించు వర్తమానమేమనగా.\"\n            },\n            {\n              \"Verseid\": \"62001005\",\n              \"Verse\": \"దేవుడు వెలుగు; ఆయనయందు చీకటి ఎంతమాత్రమును లేదు.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"63001001\",\n              \"Verse\": \"పెద్దయైన నేను ఏర్పరచబడిన అమ్మకును ఆమె పిల్లలకును.\"\n            },\n            {\n              \"Verseid\": \"63001002\",\n              \"Verse\": \"మనయందు నిలిచియుండి ఎల్లకాలము మనతో కూడ ఉండు సత్యమునుబట్టి.\"\n            },\n            {\n              \"Verseid\": \"63001003\",\n              \"Verse\": \"కృపయు కనికరమును సమాధానమును మీకు కలుగును గాక.\"\n            },\n            {\n              \"Verseid\": \"63001004\",\n              \"Verse\": \"నీ పిల్లలలో కొందరు సత్యమునందు నడుచుచుండుట చూచి నేను మిక్కిలి సంతోషించితిని.\"\n            },\n            {\n              \"Verseid\": \"63001005\",\n              \"Verse\": \"అమ్మా, క్రొత్త ఆజ్ఞవలె గాక ఆదినుండి మనకుండిన ఆజ్ఞను మీకు వ్రాయుచున్నాను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"64001001\",\n              \"Verse\": \"పెద్దయైన నేను సత్యమందు ప్రేమించు ప్రియమైన గాయికి.\"\n            },\n            {\n              \"Verseid\": \"64001002\",\n              \"Verse\": \"ప్రియుడా, నీ ఆత్మ వర్ధిల్లుచున్నట్లే నీవు అన్ని విషయములలో వర్ధిల్లుచు సుఖముగా ఉండవలెనని ప్రార్థించుచున్నాను.\"\n            },\n            {\n              \"Verseid\": \"64001003\",\n              \"Verse\": \"సహోదరులు వచ్చి నీయొక్క సత్యమునుగూర్చి సాక్ష్యమిచ్చినప్పుడు నేను మిక్కిలి సంతోషించితిని.\"\n            },\n            {\n              \"Verseid\": \"64001004\",\n              \"Verse\": \"నా పిల్లలు సత్యమునందు నడుచుచున్నారని విన్నప్పుడు అంతకంటె ఎక్కువైన సంతోషము నాకు లేదు.\"\n            },\n            {\n              \"Verseid\": \"64001005\",\n              \"Verse\": \"ప్రియుడా, నీవు సహోదరులయందు చేయుచున్నది నమ్మకముగా చేయుచున్నావు.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"65001001\",\n              \"Verse\": \"యేసుక్రీస్తు దాసుడును యాకోబు సహోదరుడునైన యూదా.\"\n            },\n            {\n              \"Verseid\": \"65001002\",\n              \"Verse\": \"కనికరమును సమాధానమును ప్రేమయును మీకు విస్తరించును గాక.\"\n            },\n            {\n              \"Verseid\": \"65001003\",\n              \"Verse\": \"ప్రియులారా, మన అందరికిని కలిగిన రక్షణనుగూర్చి మీకు వ్రాయుటకు నేను పూర్ణ ప్రయత్నము చేయుచుండగా.\"\n            },\n            {\n              \"Verseid\": \"65001004\",\n              \"Verse\": \"కొందరు మనుష్యులు రహస్యముగా జొరబడియున్నారు.\"\n            },\n            {\n              \"Verseid\": \"65001005\",\n              \"Verse\": \"కాబట్టి మీకు ఒక సారి జ్ఞాపకము చేయగోరుచున్నాను.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"66001001\",\n              \"Verse\": \"దేవుడు యేసుక్రీస్తునకు అనుగ్రహించిన ప్రకటన.\"\n            },\n            {\n              \"Verseid\": \"66001002\",\n              \"Verse\": \"ఈ ప్రవచన వాక్యములు చదువువాడును వినువారును ధన్యులు.\"\n            },\n            {\n              \"Verseid\": \"66001003\",\n              \"Verse\": \"ఆసియలో ఉన్న ఏడు సంఘములకు యోహాను వ్రాయునది.\"\n            },\n            {\n              \"Verseid\": \"66001004\",\n              \"Verse\": \"ఉన్నవాడును ఉండినవాడును రాబోవువాడునైన వానినుండి కృపయు సమాధానమును మీకు కలుగును గాక.\"\n            },\n            {\n              \"Verseid\": \"66001005\",\n              \"Verse\": \"నమ్మకమైన సాక్షియు మృతులలో ఆదిసంభూతుడునైన యేసుక్రీస్తునుండి.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"66002001\",\n              \"Verse\": \"ప్రభువు దినమందు ఆత్మవశుడనై యుంటిని; నా వెనుక బూర ధ్వనివంటి గొప్ప స్వరము విని.\"\n            },\n            {\n              \"Verseid\": \"66002002\",\n              \"Verse\": \"నేను అల్ఫాయు ఓమేగయు మొదటివాడను కడపటివాడను.\"\n            },\n            {\n              \"Verseid\": \"66002003\",\n              \"Verse\": \"నా