{"dependencies":[],"output":[{"data":{"code":"__d(function(global, require, _importDefaultUnused, _importAllUnused, module, exports, _dependencyMapUnused) {\n  module.exports = {\n  \"Book\": [\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01001001\",\n              \"Verse\": \"ఆదియందు దేవుడు భూమ్యాకాశములను సృజించెను.\"\n            },\n            {\n              \"Verseid\": \"01001002\",\n              \"Verse\": \"భూమి నిరాకారముగాను శూన్యముగాను ఉండెను; చీకటి అగాధజలము పైన కమ్మియుండెను, దేవుని ఆత్మ జలముల పైన అల్లాడుచుండెను.\"\n            },\n            {\n              \"Verseid\": \"01001003\",\n              \"Verse\": \"దేవుడు వెలుగు కమ్మని పలికెను; వెలుగు కలిగెను.\"\n            },\n            {\n              \"Verseid\": \"01001004\",\n              \"Verse\": \"వెలుగు మంచిదైనట్టు దేవుడు చూచెను; దేవుడు వెలుగును చీకటిని వేరుపరచెను.\"\n            },\n            {\n              \"Verseid\": \"01001005\",\n              \"Verse\": \"దేవుడు వెలుగునకు పగలనియు, చీకటికి రాత్రి అనియు పేరు పెట్టెను. అస్తమయమును ఉదయమును కలుగగా ఒక దినము ఆయెను.\"\n            },\n            {\n              \"Verseid\": \"01001006\",\n              \"Verse\": \"మరియు దేవుడు జలముల మధ్య విశాలము కలిగి, జలములను జలములను వేరుచేయునదని పలికెను.\"\n            },\n            {\n              \"Verseid\": \"01001007\",\n              \"Verse\": \"దేవుడు ఆ విశాలమును చేసి, విశాలము క్రింది జలములను విశాలము పైనున్న జలములను వేరుపరచెను; ఆ ప్రకారమాయెను.\"\n            },\n            {\n              \"Verseid\": \"01001008\",\n              \"Verse\": \"దేవుడు ఆ విశాలమునకు ఆకాశమని పేరు పెట్టెను. అస్తమయమును ఉదయమును కలుగగా రెండవ దినము ఆయెను.\"\n            },\n            {\n              \"Verseid\": \"01001009\",\n              \"Verse\": \"దేవుడు ఆకాశముక్రింది జలములు ఒకచోటికి పోగై పొడినేల కనబడునుగాక అని పలికెను; ఆ ప్రకారమాయెను.\"\n            },\n            {\n              \"Verseid\": \"01001010\",\n              \"Verse\": \"దేవుడు పొడినేలకు భూమి అనియు, జలరాశికి సముద్రములనియు పేరు పెట్టెను; అది మంచిదైనట్టు దేవుడు చూచెను.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"01002001\",\n              \"Verse\": \"ఆ ప్రకారము భూమ్యాకాశములును, వాటి సర్వసమూహమును సంపూర్ణమాయెను.\"\n            },\n            {\n              \"Verseid\": \"01002002\",\n              \"Verse\": \"దేవుడు తాను చేసిన తన పనిని ఏడవ దినమందు సంపూర్ణ చేసెను; తాను చేసిన తన పని అంతటినుండి ఏడవ దినమందు విశ్రమించెను.\"\n            },\n            {\n              \"Verseid\": \"01002003\",\n              \"Verse\": \"కాబట్టి దేవుడు ఏడవ దినమును ఆశీర్వదించి పరిశుద్ధపరచెను; ఏలయనగా దేవుడు సృజించి చేసిన తన పని అంతటినుండి ఆ దినమందు విశ్రమించెను.\"\n            },\n            {\n              \"Verseid\": \"01002004\",\n              \"Verse\": \"భూమ్యాకాశములు సృజింపబడిన నాటి వృత్తాంతము ఇది. దేవుడైన యెహోవా భూమ్యాకాశములను చేసిన దినమందు\"\n            },\n            {\n              \"Verseid\": \"01002005\",\n              \"Verse\": \"పొలములో మొక్కయు భూమిమీద గడ్డియు మొలవలేదు; ఏలయనగా దేవుడైన యెహోవా భూమిమీద వర్షము కురిపించలేదు.\"\n            }\n          ]\n        }\n      ]\n    },\n    {\n      \"Chapter\": [\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19001001\",\n              \"Verse\": \"భక్తిహీనుల ఆలోచన చొప్పున నడువక పాపుల మార్గమున నిలువక అపహాసకులు కూర్చుండు చోటను కూర్చుండని వాడు ధన్యుడు.\"\n            },\n            {\n              \"Verseid\": \"19001002\",\n              \"Verse\": \"యెహోవా ధర్మశాస్త్రమునందు అతడు ఆనందించును. దివారాత్రము దానిని ధ్యానించును.\"\n            },\n            {\n              \"Verseid\": \"19001003\",\n              \"Verse\": \"అతడు నీటి కాలువల ప్రక్కన నాటబడి ఆకు వాడక తన కాలమందు ఫలమిచ్చు చెట్టువలె నుండును. అతడు చేయునదంతయు సఫలమగును.\"\n            },\n            {\n              \"Verseid\": \"19001004\",\n              \"Verse\": \"భక్తిహీనులు అట్లుండరు, గాలికి ఎగురగొట్టబడు పొట్టువలె నుందురు.\"\n            },\n            {\n              \"Verseid\": \"19001005\",\n              \"Verse\": \"కాబట్టి న్యాయవిమర్శలో భక్తిహీనులును నీతిమంతుల సభలో పాపులును నిలువలేరు.\"\n            },\n            {\n              \"Verseid\": \"19001006\",\n              \"Verse\": \"నీతిమంతుల మార్గమును యెహోవా జ్ఞాపకముంచును భక్తిహీనుల మార్గము నాశనమగును.\"\n            }\n          ]\n        },\n        {\n          \"Verse\": [\n            {\n              \"Verseid\": \"19023001\",\n              \"Verse\": \"యెహోవా నా కాపరి; నాకు లేమి కలుగదు.\"\n            },\n            {\n              \"Verseid\": \"19023002\",\n              \"Verse\": \"పచ్చిక బయళ్లలో ఆయన నన్ను పరుండజేయును. సేదదీర్చు జలములయొద్దకు నన్ను నడిపించును.\"\n            },\n            {\n              \"Verseid\": \"19023003\",\n              \"Verse\": \"ఆయన నా ప్రాణమును తెప్పరిల్లజేయును. తన నామమునుబట్టి నీతిమార్గములలో నన్ను నడిపించును.\"\n            },\n            {\n              \"Verseid\": \"19023004\",\n              \"Verse\": \"గాఢాంధకారపు లోయలో నేను సంచరించినను ఏ అపాయమునకు భయపడను. నీవు నాకు తోడై యుందువు. నీ దుడ్డుకఱ్ఱయు నీ చేతికఱ్ఱయు నన్ను ఆదరించును.\"\n            },\n            {\n              \"Verseid\": \"19023005\",\n              \"Verse\": \"నా శత్రువులయెదుట నీవు నాకు భోజనము సిద్ధపరచుదువు. నూనెతో నా తల అంటియున్నావు. నా గిన్నె నిండి పొర్లుచున్నది.\"\n            },\n            {\n              \"Verseid\": \"19023006\",\n              \"Verse\": \"నా జీవితకాలమంతయు నన్ను శుభమును కృపయును వెంబడించును. చిరకాలము యెహోవా మందిరములో నేను నివసించెదను.\"\n            }\n          ]\n        }\n      ]\n    }\n  ]\n};\n});","lineCount":138,"map":[[138,3]],"functionMap":null},"type":"js/module"}]}